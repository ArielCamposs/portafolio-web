<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tómate un Respiro</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
    <style>
        :root {
            --black: #1A1A1A;
            --soft-beige: #E6E1DD;
            --beige: #C6BBB2;
            --font-geist: 'Geist', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--black);
            overflow: hidden;
            font-family: var(--font-geist);
        }

        body.hide-cursor,
        body.hide-cursor * {
            cursor: none !important;
        }

        /* Rejilla de Fondo */
        .break-grid-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: space-between;
            pointer-events: none;
        }

        .break-grid-line {
            width: 1px;
            height: 100%;
            background-color: rgba(255, 255, 255, 0.08);
        }

        .break-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .break-overlay-content {
            position: relative;
            z-index: 3;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            height: 100%;
            width: 100%;
            padding: 4rem 1.5rem;
        }

        .break-group {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .break-label,
        .break-line-inner,
        .break-hint-inner {
            font-size: clamp(0.75rem, 1.2vw, 0.95rem);
            font-weight: 400;
            color: var(--soft-beige);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            text-align: center;
        }

        .break-countdown-time,
        .break-cta-inner {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            color: var(--soft-beige);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            line-height: 1;
            margin: 0.5rem 0;
        }

        .break-line {
            overflow: hidden;
            line-height: 1.3;
        }

        .break-line-inner {
            display: block;
            transform: translateY(120%);
            transition: transform 0.5s ease;
        }

        .break-cta {
            overflow: hidden;
            margin-top: 1rem;
            border: 1px solid rgba(230, 225, 221, 0.2);
            padding: 0.8rem 2rem;
            border-radius: 50px;
            transition: border-color 0.3s ease;
        }

        .break-cta:hover {
            border-color: var(--soft-beige);
        }

        .break-cta-inner {
            display: block;
            transform: translateY(120%);
            font-size: 1.2rem;
            font-weight: 700;
        }

        /* Ojos en el centro */
        .break-eyes-container {
            display: flex;
            justify-content: center;
            gap: clamp(20px, 4vw, 50px);
            margin: 2rem 0;
        }

        .break-eye {
            width: clamp(140px, 20vw, 260px);
            overflow: hidden;
        }

        .break-eye-shape {
            width: 100%;
            height: 100%;
            transform-origin: center center;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .break-eye-white {
            fill: var(--soft-beige);
        }

        .break-pupil {
            fill: var(--black);
        }

        /* Pistas del Cursor */
        .break-cursor-hint {
            position: fixed;
            font-size: 0.75rem;
            font-weight: 400;
            color: var(--soft-beige);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            pointer-events: none;
            z-index: 10;
            transform: translate(-50%, -50%);
            opacity: 0;
            white-space: nowrap;
        }

        .break-tap-hint {
            display: none;
            position: absolute;
            top: 38%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 0.8rem;
            color: var(--soft-beige);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            pointer-events: none;
            z-index: 10;
            opacity: 0;
        }

        @media (max-width: 768px) {
            .break-cursor-hint {
                display: none !important;
            }

            .break-tap-hint {
                display: block;
            }
        }
    </style>
</head>
<body>
    <div class="break-overlay">
        <!-- Rejilla decorativa de fondo -->
        <div class="break-grid-background">
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
            <div class="break-grid-line"></div>
        </div>

        <div class="break-overlay-content">
            <!-- Bloque Superior -->
            <div class="break-group">
                <div class="break-label">TIEMPO HASTA LAS 16:20</div>
                <div class="break-countdown">
                    <span class="break-countdown-time">00:00:00</span>
                </div>
                <div class="break-line">
                    <span class="break-line-inner">PERO MÍRATE...</span>
                </div>
            </div>

            <!-- Contenedor de Ojos Interactivos -->
            <div class="break-eyes-container">
                <div class="break-eye break-eye-left">
                    <svg class="break-eye-shape" viewBox="0 0 335.4 168.2">
                        <path class="break-eye-white" d="M167.7,20.9C101.3,20.9,41.6,49.3,0,94.6c41.6,45.3,101.3,73.6,167.7,73.6s126.1-28.4,167.7-73.6c-41.6-45.3-101.3-73.6-167.7-73.6Z"/>
                        <circle class="break-pupil" cx="167.7" cy="84.1" r="70"/>
                    </svg>
                </div>
                <div class="break-eye break-eye-right">
                    <svg class="break-eye-shape" viewBox="0 0 335.4 168.2">
                        <path class="break-eye-white" d="M167.7,20.9C101.3,20.9,41.6,49.3,0,94.6c41.6,45.3,101.3,73.6,167.7,73.6s126.1-28.4,167.7-73.6c-41.6-45.3-101.3-73.6-167.7-73.6Z"/>
                        <circle class="break-pupil" cx="167.7" cy="84.1" r="70"/>
                    </svg>
                </div>
            </div>

            <!-- Bloque Inferior -->
            <div class="break-group">
                <div class="break-line">
                    <span class="break-line-inner">OBVIAMENTE NECESITAS UN RESPIRO</span>
                </div>
                <div class="break-cta" id="breakCta">
                    <span class="break-cta-inner">Adelante</span>
                </div>
            </div>
        </div>

        <div class="break-cursor-hint">HAZ CLIC AQUÍ</div>
        <div class="break-tap-hint">TOCA LA PANTALLA</div>
    </div>

    <!-- GSAP de CDN -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline>
        let breakEyesAnimating = true;

        function stopBreakEyesAnimation() {
            breakEyesAnimating = false;
        }

        // Cuenta regresiva
        function initCountdown() {
            const timeEl = document.querySelector('.break-countdown-time');
            if (!timeEl) return;

            function update() {
                const now = new Date();
                const target = new Date();
                target.setHours(16, 20, 0, 0);

                if (now >= target) {
                    target.setDate(target.getDate() + 1);
                }

                const diff = target.getTime() - now.getTime();
                const hours = Math.floor(diff / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                timeEl.textContent = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }

            update();
            setInterval(update, 1000);
        }

        // Movimiento de pupilas que siguen al mouse
        function initEyes() {
            const eyes = document.querySelectorAll('.break-eye');
            if (eyes.length === 0) return;

            let mouseX = window.innerWidth / 2;
            let mouseY = window.innerHeight / 2;

            const pupilPositions = new Map();
            eyes.forEach(eye => {
                pupilPositions.set(eye, { x: 0, y: 0 });
            });

            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });

            function animate() {
                if (!breakEyesAnimating) return;
                eyes.forEach(eye => {
                    const pupil = eye.querySelector('.break-pupil');
                    if (!pupil) return;

                    const rect = eye.getBoundingClientRect();
                    const cx = rect.left + rect.width / 2;
                    const cy = rect.top + rect.height / 2;

                    const dx = mouseX - cx;
                    const dy = mouseY - cy;
                    const angle = Math.atan2(dy, dx);
                    const dist = Math.sqrt(dx * dx + dy * dy);

                    const maxMoveX = 25;
                    const maxMoveY = 15;
                    const ratio = Math.min(dist / 150, 1);
                    const tx = Math.cos(angle) * maxMoveX * ratio;
                    const ty = Math.sin(angle) * maxMoveY * ratio;

                    const pos = pupilPositions.get(eye);
                    pos.x += (tx - pos.x) * 0.15;
                    pos.y += (ty - pos.y) * 0.15;

                    pupil.setAttribute('transform', `translate(${pos.x}, ${pos.y})`);
                });
                requestAnimationFrame(animate);
            }
            animate();
        }

        // Inicializar animaciones de entrada con GSAP
        document.addEventListener('DOMContentLoaded', () => {
            const overlay = document.querySelector('.break-overlay');
            const hint = document.querySelector('.break-cursor-hint');

            // Seguir mouse con pista de cursor
            document.addEventListener('mousemove', (e) => {
                if (hint) {
                    hint.style.left = e.clientX + 'px';
                    hint.style.top = e.clientY + 'px';
                }
            });

            initCountdown();
            initEyes();

            // Animación de entrada
            const tl = gsap.timeline();
            tl.to(overlay, { opacity: 1, duration: 0.4 })
              .from('.break-label', { opacity: 0, y: 20, duration: 0.4 }, '-=0.2')
              .from('.break-countdown-time', { opacity: 0, y: 30, duration: 0.5 }, '-=0.3')
              .to('.break-line-1 .break-line-inner, .break-line-inner', { y: '0%', duration: 0.6, stagger: 0.1, ease: 'power3.out' }, '-=0.3')
              .to('.break-eye-shape', { opacity: 1, duration: 0.5 }, '-=0.2')
              .add(() => {
                  if (window.innerWidth > 768) {
                      document.body.classList.add('hide-cursor');
                  }
              })
              .to('.break-cursor-hint, .break-tap-hint', { opacity: 1, duration: 0.4 })
              .to('.break-cta-inner', { y: '0%', duration: 0.6, ease: 'power3.out' }, '-=0.2');

            // Hacer clic para salir (redirección)
            document.addEventListener('click', () => {
                const params = new URLSearchParams(window.location.search);
                const from = params.get('from');
                const exitUrl = '/dramatic-exit' + (from ? '?from=' + from : '');

                const exitTl = gsap.timeline({
                    onComplete: () => {
                        window.location.href = exitUrl;
                    }
                });

                exitTl.to('.break-cursor-hint, .break-tap-hint', { opacity: 0, duration: 0.2 })
                      .to('.break-cta-inner, .break-line-inner', { y: '-120%', duration: 0.4, stagger: 0.05, ease: 'power3.in' }, '-=0.1')
                      .to('.break-countdown, .break-label', { opacity: 0, y: -20, duration: 0.3 }, '-=0.2')
                      .add(() => { stopBreakEyesAnimation(); })
                      .to('.break-pupil', { attr: { transform: 'translate(0, 0)' }, duration: 0.1 })
                      .to('.break-eye-shape', { scaleY: 0.1, opacity: 0, duration: 0.5, ease: 'power2.inOut' })
                      .to({}, { duration: 0.3 }); // Sostener negro
            });
        });
    </script>
</body>
</html>
