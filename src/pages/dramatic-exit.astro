<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salida Dramática</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #1A1A1A;
            min-height: 100vh;
            overflow: hidden;
            font-family: 'Geist', sans-serif;
        }

        .ray-composition {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            transform: scale(0);
            transform-origin: center center;
        }

        .ray {
            position: absolute;
            top: calc(50% - 128.5px);
            left: 50%;
            width: 1477px;
            height: 257px;
            transform-origin: 0 50%;
        }

        .cat-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 10;
            pointer-events: none;
            opacity: 0;
        }

        .cat {
            width: 320px;
            height: auto;
            display: block;
        }

        #mobileEyesCanvas {
            display: none;
        }

        /* Enlace de regreso */
        .back-to-normal-link {
            position: fixed;
            bottom: 1.5em;
            right: 1.5em;
            display: flex;
            align-items: flex-end;
            gap: 12px;
            text-decoration: none;
            z-index: 100;
            opacity: 0;
            transform: translateY(20px);
        }

        .back-to-normal-text {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
        }

        .btn-line {
            display: block;
            font-family: 'Geist', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            color: #1A1A1A;
            background-color: #A199FF;
            text-transform: uppercase;
            padding: 0.25em 0.5em;
            line-height: 1;
            letter-spacing: 0.05em;
            margin-top: 2px;
            width: fit-content;
        }

        .door-icon {
            width: 80px;
            height: auto;
            display: block;
        }

        .door-handle {
            transition: opacity 0.3s ease;
        }

        .back-to-normal-link:hover .door-handle {
            opacity: 0;
        }

        @media (max-width: 768px) {
            .ray-composition {
                position: fixed;
                top: 50%;
                left: 50%;
                width: 300vmax;
                height: 300vmax;
                transform: translate(-50%, -50%);
                overflow: visible;
            }

            .ray {
                width: 150vmax;
                height: auto;
                top: 50%;
                left: 50%;
                margin-top: -13vmax;
            }

            .cat-container {
                position: fixed;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
            }

            .cat {
                width: 250px;
            }

            .back-to-normal-link {
                right: 50%;
                transform: translateX(50%);
                bottom: 2em;
            }
        }
    </style>
</head>
<body>
    <div class="ray-composition"></div>
    <div class="cat-container" id="catContainer">
        <!-- El gato interactivo -->
        <img src="/images/cat.svg" alt="Gato psicodélico" class="cat" id="cat">
        <canvas id="mobileEyesCanvas"></canvas>
    </div>

    <!-- Botón de regreso -->
    <a href="/" class="back-to-normal-link" id="backLink">
        <div class="back-to-normal-text">
            <span class="btn-line">VOLVER A LA</span>
            <span class="btn-line">NORMALIDAD EN</span>
            <span class="btn-line countdown" id="countdown">60s</span>
        </div>
        <svg class="door-icon" xmlns="http://www.w3.org/2000/svg" width="89.3" height="131.9" viewBox="0 0 89.3 131.9">
            <path d="M44.6,9.1c-19.6,0-35.5,15.9-35.5,35.5v78.2h71.1V44.6c0-19.6-15.9-35.5-35.5-35.5Z" fill="#1a1a1a"/>
            <circle class="door-handle" cx="26" cy="82.5" r="5.6" fill="#a199ff"/>
            <path d="M44.6,0C20,0,0,20,0,44.6v87.3h89.3V44.6C89.3,20,69.3,0,44.6,0ZM80.2,122.8H9.1V44.6c0-19.6,15.9-35.5,35.5-35.5s35.5,15.9,35.5,35.5v78.2Z" fill="#a199ff"/>
        </svg>
    </a>

    <!-- GSAP de CDN -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline>
        const SVG_HEIGHT = 257.3;
        const RAY_COUNT = 36;
        const isMobile = window.innerWidth <= 768;

        const originalPath = [
            ['M', 1378.1, 99.2],
            ['c', -43.3, 8.2, -89.7, 14.9, -131.8, -2],
            ['c', -35.2, -14.1, -58.5, -43.8, -90.6, -62.4],
            ['c', -24.5, -14.2, -50.9, -25.2, -78.7, -30.9],
            ['c', -56.4, -11.4, -114.5, 1.4, -156.4, 42.1],
            ['c', -56, 54.4, -83.5, 133.2, -176.9, 123],
            ['c', -67.4, -7.4, -100.6, -63, -158.9, -87],
            ['c', -102.3, -42.1, -179.8, 16.3, -218.2, 74.8],
            ['s', -78, 70.9, -78, 70.9],
            ['c', 0, 0, -80.3, 36.8, -162.5, -27.2],
            ['C', 43.8, 136.4, 0, 132, 0, 132],
            ['c', 97.1, 44.5, 133.5, 87.4, 133.5, 87.4],
            ['c', 45.9, 34.5, 102.3, 49.1, 157.2, 28.2],
            ['c', 58.4, -22.3, 79.9, -71.8, 124.1, -110.6],
            ['c', 41.2, -36.2, 113.2, -43.1, 161, -15.5],
            ['c', 44.7, 25.7, 79, 63.1, 126.7, 85.9],
            ['c', 74.4, 35.7, 150.4, 2.9, 205.1, -51.5],
            ['c', 36.9, -36.7, 72.7, -82.9, 129.4, -84.2],
            ['c', 35.7, -0.8, 61.9, 18.3, 89.5, 37.9],
            ['c', 32.8, 23.3, 66.6, 45.7, 103.1, 62.9],
            ['c', 43.7, 20.5, 89.3, 31.4, 137.5, 30.8],
            ['c', 14.6, -0.2, 87.8, 1.2, 91.2, -18.9],
            ['c', 0, -0.1, 19, -111.8, 19, -111.8],
            ['c', -2.1, 12.1, -87.1, 24.4, -99.2, 26.7],
            ['Z']
        ];

        function generatePath(t) {
            let d = '';
            for (const seg of originalPath) {
                const cmd = seg[0];
                if (cmd === 'Z') {
                    d += 'Z';
                    continue;
                }
                const isAbsolute = cmd === cmd.toUpperCase();
                const values = seg.slice(1);
                d += cmd;
                for (let i = 0; i < values.length; i++) {
                    const isY = (i % 2 === 1);
                    let val = values[i];
                    if (isY) {
                        const flippedVal = isAbsolute ? SVG_HEIGHT - val : -val;
                        val = flippedVal * t + val * (1 - t);
                    }
                    d += (i > 0 ? ',' : '') + val.toFixed(1);
                }
            }
            return d;
        }

        function createRays() {
            const comp = document.querySelector('.ray-composition');
            const list = [];
            for (let i = 0; i < RAY_COUNT; i++) {
                const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
                svg.setAttribute('viewBox', '0 0 1477.3 257.3');
                svg.setAttribute('class', 'ray');
                svg.style.transform = `rotate(${i * 10}deg)`;

                const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                path.setAttribute('fill', 'rgba(161, 153, 255, 0.5)');
                path.setAttribute('d', generatePath(0));

                svg.appendChild(path);
                comp.appendChild(svg);
                list.push(path);
            }
            return list;
        }

        let rays = [];
        let compContainer = null;
        let rotation = 0;
        let mouseT = 0.5;
        let currentT = 0;
        let targetT = 0;

        function init() {
            rays = createRays();
            compContainer = document.querySelector('.ray-composition');

            // Entrada animada
            const tl = gsap.timeline({
                onComplete: () => {
                    requestAnimationFrame(animate);
                }
            });

            tl.to({}, { duration: 0.25 })
              .to('.ray-composition', {
                  opacity: 1,
                  scale: 1,
                  xPercent: isMobile ? -50 : 0,
                  yPercent: isMobile ? -50 : 0,
                  duration: 1.5,
                  ease: "power4.out"
              })
              .to('.cat-container', { opacity: 1, duration: 0.8 }, '-=0.8')
              .to('.back-to-normal-link', { opacity: 1, y: 0, duration: 0.6 }, '-=0.4');
        }

        function animate() {
            if (!compContainer) return;
            if (isMobile) {
                rotation += 0.15;
                compContainer.style.transform = `translate(-50%, -50%) rotate(${rotation}deg)`;
            } else {
                rotation += (mouseT - 0.5) * 0.05;
                compContainer.style.transform = `scale(1) rotate(${rotation}deg)`;

                currentT += (targetT - currentT) * 0.08;
                const d = generatePath(currentT);
                rays.forEach(r => r.setAttribute('d', d));
            }
            requestAnimationFrame(animate);
        }

        if (!isMobile) {
            document.addEventListener('mousemove', (e) => {
                mouseT = e.clientX / window.innerWidth;
                targetT = mouseT < 0.5 ? (mouseT / 0.5) * 0.35 : 0.65 + ((mouseT - 0.5) / 0.5) * 0.35;
            });
        }

        // Repulsión del gato
        const cat = document.getElementById('cat');
        const catContainer = document.getElementById('catContainer');
        let baseX = window.innerWidth / 2;
        let baseY = window.innerHeight / 2;
        let cx = baseX, cy = baseY, tx = baseX, ty = baseY;

        if (isMobile) {
            document.addEventListener('click', (e) => {
                // @ts-ignore
                if (e.target.closest('.back-to-normal-link')) return;
                const dx = baseX - e.clientX;
                const dy = baseY - e.clientY;
                const angle = Math.atan2(dy, dx);
                tx = baseX + Math.cos(angle) * 80;
                ty = baseY + Math.sin(angle) * 80;

                setTimeout(() => { tx = baseX; ty = baseY; }, 150);
            });

            function animMobileCat() {
                cx += (tx - cx) * 0.12;
                cy += (ty - cy) * 0.12;
                // @ts-ignore
                catContainer.style.transform = `translate(calc(-50% + ${cx - baseX}px), calc(-50% + ${cy - baseY}px))`;
                requestAnimationFrame(animMobileCat);
            }
            animMobileCat();
        } else {
            document.addEventListener('mousemove', (e) => {
                const dx = baseX - e.clientX;
                const dy = baseY - e.clientY;
                const dist = Math.sqrt(dx * dx + dy * dy);

                if (dist < 400) {
                    const force = (1 - dist / 400) * 200;
                    const angle = Math.atan2(dy, dx);
                    tx = baseX + Math.cos(angle) * force;
                    ty = baseY + Math.sin(angle) * force;
                } else {
                    tx = baseX;
                    ty = baseY;
                }
            });

            function animCat() {
                cx += (tx - cx) * 0.03;
                cy += (ty - cy) * 0.03;
                if (cat) {
                    cat.style.left = cx + 'px';
                    cat.style.top = cy + 'px';
                }
                requestAnimationFrame(animCat);
            }
            animCat();
        }

        // Espirales hipnóticas en los ojos móviles/escritorio
        const mobileEyesCanvas = document.getElementById('mobileEyesCanvas');
        if (mobileEyesCanvas instanceof HTMLCanvasElement && cat) {
            const mctx = mobileEyesCanvas.getContext('2d');
            let mTime = 0;

            const drawSpirals = () => {
                const w = cat.offsetWidth;
                const h = cat.offsetHeight;

                if (w === 0) {
                    requestAnimationFrame(drawSpirals);
                    return;
                }

                mobileEyesCanvas.width = w * 2;
                mobileEyesCanvas.height = h * 2;
                mobileEyesCanvas.style.width = w + 'px';
                mobileEyesCanvas.style.height = h + 'px';
                mobileEyesCanvas.style.display = 'block';
                mobileEyesCanvas.style.position = 'absolute';
                mobileEyesCanvas.style.top = '0';
                mobileEyesCanvas.style.left = '0';

                const scale = (w * 2) / 812.7;
                const eyes = [
                    { x: 330.7 * scale, y: 254.8 * scale, radius: 45 * scale },
                    { x: 482 * scale, y: 254.8 * scale, radius: 45 * scale }
                ];

                function loop() {
                    mTime += 0.02;
                    if (!mctx) return;
                    mctx.clearRect(0, 0, mobileEyesCanvas.width, mobileEyesCanvas.height);

                    eyes.forEach(eye => {
                        mctx.save();
                        mctx.beginPath();
                        mctx.ellipse(eye.x, eye.y, eye.radius, eye.radius * 1.1, 0, 0, Math.PI * 2);
                        mctx.clip();

                        for (let arm = 0; arm < 2; arm++) {
                            const offset = (arm / 2) * Math.PI * 2;
                            mctx.beginPath();
                            for (let i = 0; i <= 60; i++) {
                                const prog = i / 60;
                                const a = prog * 2.5 * Math.PI * 2 + mTime * 2 + offset;
                                const r = prog * eye.radius;
                                const px = eye.x + Math.cos(a) * r;
                                const py = eye.y + Math.sin(a) * r;

                                if (i === 0) mctx.moveTo(px, py);
                                else mctx.lineTo(px, py);
                            }
                            mctx.lineWidth = 3;
                            mctx.strokeStyle = '#1a1a1a';
                            mctx.stroke();
                        }
                        mctx.restore();
                    });
                    requestAnimationFrame(loop);
                }
                loop();
            };

            if (cat.complete) drawSpirals();
            else cat.onload = drawSpirals;
        }

        // Lógica de parámetros de regreso
        const params = new URLSearchParams(window.location.search);
        const from = params.get('from');
        const returnUrl = from ? decodeURIComponent(from) : '/';
        const backLink = document.getElementById('backLink');
        if (backLink instanceof HTMLAnchorElement) backLink.href = returnUrl;

        // Contador de 60 segundos
        let left = 60;
        const countEl = document.getElementById('countdown');
        const interval = setInterval(() => {
            left--;
            if (countEl) countEl.textContent = left + 's';
            if (left <= 0) {
                clearInterval(interval);
                window.location.href = returnUrl;
            }
        }, 1000);

        init();
    </script>
</body>
</html>
