---
interface Props {
    title: string;
    description?: string;
}
const {
    title,
    description = "Ariel Campos - Analista Programador Computacional. Creando interfaces modernas, eficientes e interactivas.",
} = Astro.props;

import ProjectDrawer from "../components/ProjectDrawer.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es" data-theme="light">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />

        <script is:inline>
            // Configurar tema inicial por defecto (light)
            (function() {
                var pageTheme = 'light';
                document.documentElement.setAttribute('data-theme', pageTheme);
            })();
        </script>

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Geist:wght@100..900&family=Bebas+Neue&display=swap" rel="stylesheet" />

        <!-- SEO Primario -->
        <title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={description} />
        <meta name="author" content="Ariel Campos" />
        <meta name="keywords" content="Ariel Campos, Portafolio, Programador Web, Analista Programador, React, Astro, Tailwind CSS, Chile, Desarrollo Web" />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://arielcampos.dev/" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content="/images/og-image.jpg" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content="https://arielcampos.dev/" />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content="/images/og-image.jpg" />
    </head>
    <body class="index-page">
        <!-- Pantalla de Carga (Loader con columnas) -->
        <div class="loader">
            <div class="loader-col"></div>
            <div class="loader-col"></div>
            <div class="loader-col"></div>
            <div class="loader-col"></div>
            <div class="loader-col"></div>
            <div class="loader-col"></div>
            <div class="loader-col"></div>
            <div class="loader-col"></div>
            <div class="loader-content">
                <div class="loader-counter">0%</div>
            </div>
        </div>

        <!-- Cuadrícula de Fondo (Grid lines) -->
        <div class="grid-background">
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
            <div class="line"></div>
        </div>

        <!-- Contenedor de Contenido Principal -->
        <slot />

        <!-- Detalles del Proyecto (Drawer de información) -->
        <ProjectDrawer />

        <!-- CDN Scripts (GSAP, ScrollTrigger, Lenis) -->
        <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
        <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
        <script is:inline src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>

        <!-- Lógica de Preloader (loader.js) -->
        <script is:inline>
            (function() {
                'use strict';
                const loader = document.querySelector('.loader');
                const loaderCounter = document.querySelector('.loader-counter');
                const loaderCols = document.querySelectorAll('.loader-col');

                if (!loader || !loaderCounter) return;

                const images = Array.from(document.querySelectorAll('img'));
                const bgElements = Array.from(document.querySelectorAll('[style*="background-image"]'));

                // Forzar imágenes a cargar inmediatamente
                images.forEach(img => {
                    if (img.loading === 'lazy') {
                        img.loading = 'eager';
                    }
                });

                const totalAssets = images.length + bgElements.length;
                let loadedAssets = 0;
                let displayedPercent = 0;

                if (totalAssets === 0) {
                    animateToPercent(100, completeLoader);
                    return;
                }

                function updateProgress() {
                    loadedAssets++;
                    const actualPercent = Math.min(100, Math.round((loadedAssets / totalAssets) * 100));
                    animateToPercent(actualPercent, loadedAssets >= totalAssets ? completeLoader : null);
                }

                function animateToPercent(targetPercent, onComplete) {
                    const animate = () => {
                        if (displayedPercent < targetPercent) {
                            displayedPercent += Math.ceil((targetPercent - displayedPercent) / 10) || 1;
                            if (displayedPercent > targetPercent) displayedPercent = targetPercent;
                            loaderCounter.textContent = displayedPercent + '%';
                            requestAnimationFrame(animate);
                        } else if (onComplete) {
                            onComplete();
                        }
                    };
                    animate();
                }

                function completeLoader() {
                    if (typeof gsap === 'undefined') {
                        setTimeout(completeLoader, 50);
                        return;
                    }
                    const decodePromises = images.map(img => {
                        if (img.decode) {
                            return img.decode().catch(() => {});
                        }
                        return Promise.resolve();
                    });
                    Promise.all(decodePromises).then(finishLoader);
                }

                function finishLoader() {
                    const tl = gsap.timeline({
                        onComplete: () => {
                            gsap.set(loader, { display: 'none' });
                        }
                    });

                    tl.to(loaderCounter, {
                        duration: 0.5,
                        opacity: 0,
                        y: -50,
                        ease: "power2.in"
                    })
                    .to(loaderCols, {
                        duration: 1.2,
                        scaleY: 0,
                        stagger: 0.1,
                        ease: "power4.inOut",
                        onStart: () => {
                            // Animación de aparición de líneas de fondo
                            gsap.to(".grid-background .line", {
                                duration: 1.5,
                                scaleY: 1,
                                stagger: 0.08,
                                ease: "power3.inOut",
                                delay: 0.6
                            });
                            // Despachar evento global de cargador listo
                            setTimeout(() => {
                                window.dispatchEvent(new CustomEvent('loaderComplete'));
                            }, 500);
                        }
                    }, "-=0.2");
                }

                images.forEach(img => {
                    if (img.complete) {
                        updateProgress();
                    } else {
                        img.addEventListener('load', updateProgress);
                        img.addEventListener('error', updateProgress);
                    }
                });

                bgElements.forEach(el => {
                    const style = el.getAttribute('style');
                    const match = style.match(/url\(['"]?([^'")\s]+)['"]?\)/);
                    if (match && match[1]) {
                        const bgImg = new Image();
                        bgImg.onload = updateProgress;
                        bgImg.onerror = updateProgress;
                        bgImg.src = match[1];
                    } else {
                        updateProgress();
                    }
                });

                setTimeout(() => {
                    if (displayedPercent < 100) {
                        animateToPercent(100, completeLoader);
                    }
                }, 5000);
            })();
        </script>

        <!-- Lógica de Scroll Suave, Cursores y Temas (script.js) -->
        <script is:inline>
            // Registrar actualizador de ScrollTrigger con Lenis
            let lenisInstance = null;

            window.addEventListener('load', () => {
                if (typeof Lenis !== 'undefined') {
                    lenisInstance = new Lenis({
                        duration: 1.2,
                        easing: (t) => 1 - Math.pow(1 - t, 4),
                        orientation: 'vertical',
                        gestureOrientation: 'vertical',
                        smoothWheel: true,
                        wheelMultiplier: 1,
                        touchMultiplier: 2,
                    });

                    lenisInstance.on('scroll', ScrollTrigger.update);
                    
                    gsap.ticker.add((time) => {
                        lenisInstance.raf(time * 1000);
                    });
                    
                    gsap.ticker.lagSmoothing(0);
                    window.lenis = lenisInstance; // Exportar globalmente
                }

                // --- CURSORES PERSONALIZADOS ---
                initCustomCursor();

                // --- BOTÓN DE TEMA GLOBLAL ---
                initThemeToggle();

                // --- CAMBIO DE TEMA SEGÚN DESPLAZAMIENTO ---
                initScrollThemeSwitch();

                // --- PUERTAS DE ESCAPE Y CONTADOR ---
                initDoorNavigation();
                initCountdownTimer();

                // --- INTERCAMBIO DE CARACTERES ---
                initCharSwapAnimation();

                // Parallax en las líneas del Grid
                const grid = document.querySelector(".grid-background");
                window.addEventListener("mousemove", (e) => {
                    const moveX = e.clientX - window.innerWidth / 2;
                    const moveY = e.clientY - window.innerHeight / 2;
                    if (grid) {
                        gsap.to(grid, {
                            x: moveX * 0.02,
                            y: moveY * 0.02,
                            duration: 0.6,
                            ease: "power2.out"
                        });
                    }
                });
            });

            // Función para Cursores Interactivos
            function initCustomCursor() {
                const cursor = document.createElement('div');
                cursor.className = 'custom-cursor';
                cursor.innerHTML = `
                    <div class="cursor-dot"></div>
                    <div class="cursor-ring"></div>
                    <div class="cursor-text">&gt;_</div>
                `;
                document.body.appendChild(cursor);

                const viewWorkCursor = document.createElement('div');
                viewWorkCursor.className = 'view-work-cursor';
                viewWorkCursor.textContent = 'VER';
                document.body.appendChild(viewWorkCursor);

                const contactTitleCursor = document.createElement('div');
                contactTitleCursor.className = 'contact-title-cursor';
                contactTitleCursor.innerHTML = `<img src="/images/custom-cursor-hover.svg" style="width:100%; height:100%; filter: var(--theme-filter);" alt="">`;
                document.body.appendChild(contactTitleCursor);

                let mouseX = 0, mouseY = 0;
                let cursorX = 0, cursorY = 0;
                let viewX = 0, viewY = 0;
                let contactX = 0, contactY = 0;
                let skewX = 0, skewY = 0;
                let isOverContact = false;

                document.addEventListener('mousemove', (e) => {
                    mouseX = e.clientX;
                    mouseY = e.clientY;
                });

                // Detectores para animar click y spawnear efectos visuales (código / PC)
                document.addEventListener('mousedown', (e) => {
                    cursor.classList.add('clicking');

                    // 1. Crear ripple circular expansivo
                    const ripple = document.createElement('div');
                    ripple.className = 'cursor-click-ripple';
                    ripple.style.left = e.clientX + 'px';
                    ripple.style.top = e.clientY + 'px';
                    document.body.appendChild(ripple);
                    
                    // Animar ripple
                    // @ts-ignore
                    gsap.fromTo(ripple, 
                        { scale: 0.2, opacity: 0.8 },
                        { 
                            scale: 2.2, 
                            opacity: 0, 
                            duration: 0.6, 
                            ease: "power2.out",
                            onComplete: () => ripple.remove() 
                        }
                    );

                    // 2. Crear partículas flotantes de código / PC
                    const symbols = ['💻', '</>', '{}', '=>', 'const', '[]', '()', 'JS'];
                    const numParticles = 4;
                    
                    for (let i = 0; i < numParticles; i++) {
                        const particle = document.createElement('span');
                        particle.className = 'cursor-click-particle';
                        particle.textContent = symbols[Math.floor(Math.random() * symbols.length)];
                        particle.style.left = e.clientX + 'px';
                        particle.style.top = e.clientY + 'px';
                        document.body.appendChild(particle);
                        
                        const angle = Math.random() * Math.PI * 2;
                        const velocity = 35 + Math.random() * 55; // distancia
                        const targetX = Math.cos(angle) * velocity;
                        const targetY = Math.sin(angle) * velocity;
                        const rotation = (Math.random() - 0.5) * 180;
                        
                        // @ts-ignore
                        gsap.fromTo(particle,
                            { x: 0, y: 0, scale: 0.6, opacity: 1 },
                            {
                                x: targetX,
                                y: targetY,
                                scale: 1.1,
                                opacity: 0,
                                rotation: rotation,
                                duration: 0.8,
                                ease: "power3.out",
                                onComplete: () => particle.remove()
                            }
                        );
                    }
                });

                document.addEventListener('mouseup', () => {
                    cursor.classList.remove('clicking');
                });

                // Función de animación del cursor (Lerp elástico)
                function updateCursors() {
                    const cx = mouseX - cursorX;
                    const cy = mouseY - cursorY;
                    cursorX += cx * 0.16; // Interpolación para suavizado
                    cursorY += cy * 0.16;

                    cursor.style.left = cursorX + 'px';
                    cursor.style.top = cursorY + 'px';

                    // Lerp para el cursor de ver proyecto
                    const vx = mouseX - viewX;
                    const vy = mouseY - viewY;
                    viewX += vx * 0.10;
                    viewY += vy * 0.10;

                    viewWorkCursor.style.left = viewX + 'px';
                    viewWorkCursor.style.top = viewY + 'px';

                    // Lerp para cursor del contacto
                    if (isOverContact) {
                        const cox = mouseX - contactX;
                        const coy = mouseY - contactY;

                        contactX += cox * 0.12;
                        contactY += coy * 0.12;

                        const targetSkewX = Math.max(-15, Math.min(15, cox * 0.3));
                        const targetSkewY = Math.max(-15, Math.min(15, coy * 0.3));

                        skewX += (targetSkewX - skewX) * 0.15;
                        skewY += (targetSkewY - skewY) * 0.15;

                        contactTitleCursor.style.left = contactX + 'px';
                        contactTitleCursor.style.top = contactY + 'px';
                        contactTitleCursor.style.transform = `translate(-50%, -50%) scale(1) skew(${skewX}deg, ${skewY}deg)`;
                    }
                    requestAnimationFrame(updateCursors);
                }
                updateCursors();

                // Hover en botones / enlaces ordinarios
                const hoverables = document.querySelectorAll('a:not(.project-card), button, .menu-btn, .menu-link, .social-link, .contact-social-link');
                hoverables.forEach(el => {
                    el.addEventListener('mouseenter', () => {
                        cursor.classList.add('hovering');
                    });
                    el.addEventListener('mouseleave', () => {
                        cursor.classList.remove('hovering');
                    });
                });

                // Hover en proyectos
                document.addEventListener('mouseover', (e) => {
                    const card = e.target.closest('.project-card');
                    if (card) {
                        cursor.classList.add('on-project');
                        viewWorkCursor.classList.add('visible');
                    } else {
                        cursor.classList.remove('on-project');
                        viewWorkCursor.classList.remove('visible');
                    }
                });
            }

            // Inicialización de Switcher de Tema
            function initThemeToggle() {
                const controls = document.createElement('div');
                controls.className = 'controls-container';

                const toggle = document.createElement('button');
                toggle.className = 'theme-toggle';
                toggle.setAttribute('aria-label', 'Alternar modo oscuro');
                toggle.type = 'button';
                toggle.innerHTML = `
                    <div class="theme-toggle-sun">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <circle cx="12" cy="12" r="4"/>
                            <line x1="12" y1="2" x2="12" y2="5"/>
                            <line x1="12" y1="19" x2="12" y2="22"/>
                            <line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/>
                            <line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/>
                            <line x1="2" y1="12" x2="5" y2="12"/>
                            <line x1="19" y1="12" x2="22" y2="12"/>
                            <line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/>
                            <line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/>
                        </svg>
                    </div>
                    <div class="theme-toggle-moon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    </div>
                `;
                controls.appendChild(toggle);
                document.body.appendChild(controls);

                // Ocultar al entrar a la sección de contacto
                const fixedServices = document.getElementById('fixedServices');
                ScrollTrigger.create({
                    trigger: '.contact-section',
                    start: 'top bottom',
                    onEnter: () => {
                        controls.classList.add('hidden');
                        fixedServices?.classList.add('hidden');
                    },
                    onLeaveBack: () => {
                        controls.classList.remove('hidden');
                        fixedServices?.classList.remove('hidden');
                    }
                });

                toggle.addEventListener('click', () => {
                    const current = document.documentElement.getAttribute('data-theme');
                    const next = current === 'dark' ? 'light' : 'dark';
                    document.documentElement.setAttribute('data-theme', next);
                    updateThemeVisuals(next === 'dark');
                });
            }

            function updateThemeVisuals(isDark) {
                const toggles = document.querySelectorAll('.theme-toggle, .menu-theme-toggle');
                toggles.forEach(t => {
                    const sun = t.querySelector('.theme-toggle-sun');
                    const moon = t.querySelector('.theme-toggle-moon');
                    if (isDark) {
                        t.style.backgroundColor = 'rgba(230, 225, 221, 0.3)';
                        if (sun) sun.style.backgroundColor = 'transparent';
                        if (moon) moon.style.backgroundColor = 'rgba(26, 26, 26, 0.8)';
                    } else {
                        t.style.backgroundColor = 'rgba(26, 26, 26, 0.3)';
                        if (sun) sun.style.backgroundColor = 'rgba(230, 225, 221, 0.8)';
                        if (moon) moon.style.backgroundColor = 'transparent';
                    }
                });
            }

            // Cambiar tema automáticamente según scroll
            function initScrollThemeSwitch() {
                const aboutSection = document.querySelector('#sobre-mi');
                if (aboutSection) {
                    ScrollTrigger.create({
                        trigger: aboutSection,
                        start: 'top 70%',
                        onEnter: () => {
                            document.documentElement.setAttribute('data-theme', 'dark');
                            updateThemeVisuals(true);
                        },
                        onLeaveBack: () => {
                            document.documentElement.setAttribute('data-theme', 'light');
                            updateThemeVisuals(false);
                        }
                    });
                    // Refrescar ScrollTrigger para asegurar coordenadas correctas
                    ScrollTrigger.refresh();
                }
            }

            // Temporizador de cuenta regresiva hacia las 16:20 (4:20 PM)
            function initCountdownTimer() {
                const timers = document.querySelectorAll('.countdown-timer');
                if (timers.length === 0) return;

                function update() {
                    const now = new Date();
                    const target = new Date();
                    target.setHours(16, 20, 0, 0);

                    if (now >= target) {
                        target.setDate(target.getDate() + 1);
                    }

                    const diff = target.getTime() - now.getTime();
                    const hours = Math.floor(diff / (1000 * 60 * 60));
                    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                    const formatted = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                    timers.forEach(t => t.textContent = formatted);
                }

                update();
                setInterval(update, 1000);
            }

            // Navegación de Puerta
            function initDoorNavigation() {
                const doors = document.querySelectorAll('.contact-door-open, .hero-door-open');
                if (doors.length === 0) return;

                function is420() {
                    const now = new Date();
                    return now.getHours() === 16 && now.getMinutes() === 20;
                }

                // Auto-redirección a las 16:20
                setInterval(() => {
                    if (is420()) {
                        window.location.href = '/dramatic-exit?from=' + encodeURIComponent(window.location.pathname);
                    }
                }, 1000);

                doors.forEach(door => {
                    door.style.cursor = 'pointer';
                    door.addEventListener('click', (e) => {
                        e.preventDefault();
                        const isFromHero = door.closest('.hero-exit') !== null;
                        const returnPath = window.location.pathname + (isFromHero ? '#inicio' : '#contacto');
                        const fromParam = '?from=' + encodeURIComponent(returnPath);

                        if (is420()) {
                            window.location.href = '/dramatic-exit' + fromParam;
                        } else {
                            window.location.href = '/break' + fromParam;
                        }
                    });
                });
            }

            // Animación de Intercambio de Caracteres (Bebas Neue Text)
            function initCharSwapAnimation() {
                const elements = document.querySelectorAll('[data-char-swap]');
                elements.forEach(el => {
                    const text = el.textContent || '';
                    el.textContent = '';

                    const chars = text.split('');
                    const containers = [];

                    chars.forEach(char => {
                        const container = document.createElement('span');
                        container.className = 'char-swap-container';

                        const original = document.createElement('span');
                        original.className = 'char-swap-original';
                        original.textContent = char === ' ' ? '\u00A0' : char;

                        const clone = document.createElement('span');
                        clone.className = 'char-swap-clone';
                        clone.textContent = char === ' ' ? '\u00A0' : char;

                        container.appendChild(original);
                        container.appendChild(clone);
                        el.appendChild(container);

                        containers.push({ container, original, clone });
                    });

                    // Inicializar posiciones de los clones fuera de vista
                    containers.forEach(data => {
                        const { original, clone } = data;
                        const charWidth = original.offsetWidth;
                        const gap = 4;
                        gsap.set(clone, { x: -(charWidth + gap) });
                    });

                    // Iniciar bucle de animación aleatoria
                    setTimeout(() => {
                        startSwapLoop(containers);
                    }, 2000);
                });
            }

            function startSwapLoop(containers) {
                function shuffle(arr) {
                    const s = [...arr];
                    for (let i = s.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [s[i], s[j]] = [s[j], s[i]];
                    }
                    return s;
                }

                function animate() {
                    const filtered = containers.filter(c => c.original.textContent.trim() !== '');
                    if (filtered.length === 0) {
                        setTimeout(animate, 3000 + Math.random() * 2000);
                        return;
                    }
                    const shuffled = shuffle(filtered);
                    const data = shuffled[0];
                    const { original, clone } = data;
                    const charWidth = original.offsetWidth;
                    const gap = 4;

                    gsap.set(clone, { x: -(charWidth + gap) });
                    gsap.set(original, { x: 0 });

                    gsap.to(original, {
                        x: charWidth + gap,
                        duration: 0.5,
                        ease: "power2.inOut"
                    });

                    gsap.to(clone, {
                        x: 0,
                        duration: 0.5,
                        ease: "power2.inOut",
                        onComplete: () => {
                            gsap.set(original, { x: -(charWidth + gap) });
                            gsap.set(clone, { x: 0 });
                        }
                    });

                    setTimeout(animate, 3000 + Math.random() * 2000);
                }

                animate();
            }
        </script>
    </body>
</html>
