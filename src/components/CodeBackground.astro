---
---
<canvas id="code-bg-canvas" class="fixed inset-0 pointer-events-none -z-20 block"></canvas>

<script>
    // Palabras clave y fragmentos de código para flotar en el fondo
    const codeSnippets = [
        "const", "let", "function", "async", "await", "import", "export", "return", 
        "class", "extends", "yield", "map", "filter", "reduce", "forEach", "find", 
        "push", "pop", "useState", "useEffect", "useMemo", "useCallback", "useRef", 
        "Astro", "Tailwind", "Next.js", "&&", "||", "===", "=>", "??", "...", 
        "true", "false", "null", "undefined", "Promise", "Object", "Array", "String", 
        "() => {}", "if (ok)", "try { }", "catch (e)", "console.log()", "new Promise()",
        "<div />", "<span />", "<section>", "<Layout>", "className", "style", "href", 
        "onClick", "api", "git", "db", "npm", "docker"
    ];

    const canvas = document.getElementById("code-bg-canvas") as HTMLCanvasElement;
    if (canvas) {
        const ctx = canvas.getContext("2d");
        if (ctx) {
            let width = window.innerWidth;
            let height = window.innerHeight;
            let mouseX: number | null = null;
            let mouseY: number | null = null;
            let animationFrameId: number | null = null;
            let particles: CodeParticle[] = [];
            
            // Scroll velocity tracking variables
            let lastScrollY = window.scrollY;
            let scrollSpeed = 0;
            let targetScrollSpeed = 0;

            class CodeParticle {
                x: number;
                y: number;
                vx: number;
                vy: number;
                text: string;
                fontSize: number;
                baseOpacity: number;
                opacity: number;
                colorPrefix: string;
                offsetX: number;
                offsetY: number;
                speedFactor: number;

                constructor() {
                    this.x = Math.random() * width;
                    this.y = Math.random() * height;
                    // Velocidad de deriva ligeramente mayor para que sea más notable
                    this.vx = (Math.random() - 0.5) * 0.20;
                    this.vy = (Math.random() - 0.5) * 0.20;
                    this.text = codeSnippets[Math.floor(Math.random() * codeSnippets.length)];
                    this.fontSize = Math.floor(Math.random() * 7) + 12; // 12px a 18px
                    this.baseOpacity = Math.random() * 0.14 + 0.08; // Opacidad base más visible
                    this.opacity = this.baseOpacity;

                    // Colores de la paleta Neo de la página
                    const colors = [
                        "rgba(184, 153, 111, ", // --neo-gold: #b8996f
                        "rgba(107, 79, 124, ", // --neo-purple: #6b4f7c
                        "rgba(90, 138, 154, ", // --neo-cyan: #5a8a9a
                        "rgba(255, 255, 255, "  // Blanco
                    ];
                    this.colorPrefix = colors[Math.floor(Math.random() * colors.length)];
                    
                    this.offsetX = 0;
                    this.offsetY = 0;
                    this.speedFactor = Math.random() * 0.5 + 0.5;
                }

                update(scrollSpeed: number) {
                    // Deriva natural multiplicada por la velocidad del scroll ( lerpeado )
                    const speedMultiplier = 1 + scrollSpeed * 2.5;
                    this.x += this.vx * this.speedFactor * speedMultiplier;
                    this.y += this.vy * this.speedFactor * speedMultiplier;

                    // Envolver bordes (screen wrap) con margen extra
                    const pad = 120;
                    if (this.x < -pad) this.x = width + pad;
                    if (this.x > width + pad) this.x = -pad;
                    if (this.y < -pad) this.y = height + pad;
                    if (this.y > height + pad) this.y = -pad;

                    // Interacción con mouse/touch (Repulsión y brillo)
                    if (mouseX !== null && mouseY !== null) {
                        const dx = (this.x + this.offsetX) - mouseX;
                        const dy = (this.y + this.offsetY) - mouseY;
                        const distance = Math.sqrt(dx * dx + dy * dy);
                        const radius = window.innerWidth < 768 ? 130 : 200; // Radio de repulsión

                        if (distance < radius) {
                            const force = (radius - distance) / radius;
                            const angle = Math.atan2(dy, dx);
                            
                            // Desplazamiento máximo de repulsión
                            const maxPush = window.innerWidth < 768 ? 50 : 90;
                            const targetOffsetX = Math.cos(angle) * force * maxPush;
                            const targetOffsetY = Math.sin(angle) * force * maxPush;

                            // Suavizar la repulsión (lerp)
                            this.offsetX += (targetOffsetX - this.offsetX) * 0.08;
                            this.offsetY += (targetOffsetY - this.offsetY) * 0.08;

                             // Aumentar brillo cuando se acerca el mouse (más visible)
                            const opacityGlow = 0.38 * force;
                            this.opacity += (Math.min(0.65, this.baseOpacity + opacityGlow) - this.opacity) * 0.1;
                        } else {
                            // Retornar suavemente al flujo y opacidad original
                            this.offsetX += (0 - this.offsetX) * 0.03;
                            this.offsetY += (0 - this.offsetY) * 0.03;
                            this.opacity += (this.baseOpacity - this.opacity) * 0.03;
                        }
                    } else {
                        this.offsetX += (0 - this.offsetX) * 0.03;
                        this.offsetY += (0 - this.offsetY) * 0.03;
                        this.opacity += (this.baseOpacity - this.opacity) * 0.03;
                    }
                }

                draw(c: CanvasRenderingContext2D) {
                    c.fillStyle = `${this.colorPrefix}${this.opacity})`;
                    c.font = `bold ${this.fontSize}px monospace`;
                    c.fillText(this.text, this.x + this.offsetX, this.y + this.offsetY);
                }
            }

            const initParticles = () => {
                particles = [];
                // Reducir densidad en móviles para rendimiento óptimo
                const numParticles = width < 768 ? 20 : 55;
                for (let i = 0; i < numParticles; i++) {
                    particles.push(new CodeParticle());
                }
            };

            const resizeCanvas = () => {
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.style.width = `${width}px`;
                canvas.style.height = `${height}px`;

                const dpr = window.devicePixelRatio || 1;
                canvas.width = width * dpr;
                canvas.height = height * dpr;
                ctx.scale(dpr, dpr);

                // Re-inicializar si las dimensiones cambian sustancialmente
                initParticles();
            };

            // Event Listeners para Mouse y Touch
            window.addEventListener("mousemove", (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
            });

            window.addEventListener("mouseleave", () => {
                mouseX = null;
                mouseY = null;
            });

            window.addEventListener("touchstart", (e) => {
                if (e.touches[0]) {
                    mouseX = e.touches[0].clientX;
                    mouseY = e.touches[0].clientY;
                }
            }, { passive: true });

            window.addEventListener("touchmove", (e) => {
                if (e.touches[0]) {
                    mouseX = e.touches[0].clientX;
                    mouseY = e.touches[0].clientY;
                }
            }, { passive: true });

            window.addEventListener("touchend", () => {
                mouseX = null;
                mouseY = null;
            });

            window.addEventListener("resize", resizeCanvas);

            // Bucle principal de animación
            const loop = () => {
                ctx.clearRect(0, 0, width, height);

                // Calcular velocidad de scroll instantánea
                const currentScrollY = window.scrollY;
                const scrollDiff = Math.abs(currentScrollY - lastScrollY);
                lastScrollY = currentScrollY;
                
                // Mapear diferencia a velocidad de destino (limite de 10)
                targetScrollSpeed = Math.min(scrollDiff * 0.12, 10.0);
                
                // Amortiguación (lerp)
                scrollSpeed += (targetScrollSpeed - scrollSpeed) * 0.08;

                // Dibujar conexiones sutiles de la red
                const connectLimit = 120;
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const p1 = particles[i];
                        const p2 = particles[j];
                        const x1 = p1.x + p1.offsetX;
                        const y1 = p1.y + p1.offsetY;
                        const x2 = p2.x + p2.offsetX;
                        const y2 = p2.y + p2.offsetY;

                        const dx = x1 - x2;
                        const dy = y1 - y2;
                        const dist = Math.sqrt(dx * dx + dy * dy);

                        if (dist < connectLimit) {
                            // Conexiones brillan más al scrollear rápido
                            const lineOpacity = ((connectLimit - dist) / connectLimit) * 0.07 * (1 + scrollSpeed * 0.4);
                            ctx.strokeStyle = `rgba(255, 255, 255, ${lineOpacity})`;
                            ctx.lineWidth = 0.5;
                            ctx.beginPath();
                            ctx.moveTo(x1, y1 - p1.fontSize / 3);
                            ctx.lineTo(x2, y2 - p2.fontSize / 3);
                            ctx.stroke();
                        }
                    }
                }

                // Dibujar líneas hacia el cursor (interacción interactiva)
                if (mouseX !== null && mouseY !== null) {
                    const mouseLimit = window.innerWidth < 768 ? 130 : 200;
                    particles.forEach(p => {
                        const px = p.x + p.offsetX;
                        const py = p.y + p.offsetY;
                        const dx = px - mouseX!;
                        const dy = py - mouseY!;
                        const dist = Math.sqrt(dx * dx + dy * dy);

                        if (dist < mouseLimit) {
                            const lineOpacity = ((mouseLimit - dist) / mouseLimit) * 0.10 * (1 + scrollSpeed * 0.4);
                            ctx.strokeStyle = `${p.colorPrefix}${lineOpacity})`;
                            ctx.lineWidth = 0.5;
                            ctx.beginPath();
                            ctx.moveTo(px, py - p.fontSize / 3);
                            ctx.lineTo(mouseX!, mouseY!);
                            ctx.stroke();
                        }
                    });
                }

                // Actualizar y dibujar partículas
                particles.forEach(p => {
                    p.update(scrollSpeed);
                    p.draw(ctx);
                });

                animationFrameId = requestAnimationFrame(loop);
            };

            // Control de visibilidad de página para ahorrar batería
            document.addEventListener("visibilitychange", () => {
                if (document.hidden) {
                    if (animationFrameId) {
                        cancelAnimationFrame(animationFrameId);
                        animationFrameId = null;
                    }
                } else {
                    if (!animationFrameId) {
                        loop();
                    }
                }
            });

            // Inicialización
            resizeCanvas();
            loop();
        }
    }
</script>
