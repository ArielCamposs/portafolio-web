    title: "NITIV APP",
    category: "Plataforma SaaS",
    desc: "Sistema integral de gestión escolar para convivencia, orientadores y docentes.",
    img: "/images/nitiv-saas.webp",
    tags: ["Next.js", "React", "TypeScript", "Tailwind"],
    link: "https://nitiv-app-three.vercel.app/login",
    features: [
