---
const projects = [
  {
    title: "NITIV APP 📊",
    category: "Plataforma SaaS",
    desc: "Sistema integral de gestión escolar para equipos de convivencia, orientadores y docentes. Centraliza el seguimiento de casos, protocolos Mineduc y medición del clima escolar.",
    img: "nitiv-saas.webp",
    tags: ["Next.js", "React", "Tailwind CSS", "TypeScript", "Vercel"],
    link: "https://nitiv-app-three.vercel.app/login",
    featured: true,
    objectFit: "contain",
    features: [
      "Gestión y trazabilidad de casos (PAEC/DEC)",
      "Radar de competencia socioemocional CASEL",
      "Encuestas anónimas de clima de aula",
      "Asistente con Inteligencia Artificial",
    ],
    result: "92% de adopción docente 🚀",
    ctaText: "Visitar App"
  },
  {
    title: "BITECRAFT 🍔",
    category: "E-Commerce & Delivery",
    desc: "Aplicación web moderna y auto-administrable de delivery de comida rápida. Cuenta con carrito dinámico, checkout con formulario validado, panel de administración interactivo y animaciones fluidas.",
    img: "bitecraft.png",
    tags: ["Next.js", "React", "Tailwind CSS", "Zustand", "GSAP", "Framer Motion"],
    link: "https://tienda-comida-six.vercel.app/",
    repo: "https://github.com/ArielCamposs/tienda-comida-admin",
    featured: true,
    objectFit: "contain",
    features: [
      "Carrito de compras interactivo y persistente",
      "Panel de administración demo para gestión de pedidos",
      "Efectos visuales fluidos con GSAP y Framer Motion",
      "Formularios validados con Zod y React Hook Form",
    ],
    result: "Experiencia de compra fluida 🚀",
    ctaText: "Visitar Tienda"
  },
  {
    title: "NITIV.CL",
    category: "Landing Page",
    desc: "Landing page de la plataforma Nitiv, diseñada para colegios chilenos. Presenta el SaaS, sus pilares, beneficios y permite cotizaciones a medida.",
    img: "nitiv-landing.webp",
    tags: ["Astro", "React", "Styled Components", "SEO", "Responsive"],
    link: "https://nitiv.cl",
    objectFit: "contain",
    features: [
      "Presentación interactiva de pilares",
      "Sección de cotizaciones dinámicas",
      "Optimización SEO y carga rápida",
      "Formularios de contacto integrados",
    ],
    result: "Conversión de leads escolares 📈",
    ctaText: "Visitar Web"
  },
  {
    title: "TIENDA TEXTIL ADMINISTRABLE 🧶",
    category: "E-Commerce & Admin",
    desc: "Tienda online de alta textilería artesanal de La Ligua, con carrito dinámico, checkout por transferencia bancaria y panel de administración para gestionar productos en tiempo real.",
    img: "pura-lana.webp",
    tags: ["HTML5", "CSS3", "JavaScript", "Supabase", "Vercel"],
    link: "https://landingpage-puralana.vercel.app/",
    featured: true,
    objectFit: "contain",
    features: [
      "Carrito de compras dinámico",
      "Panel de administración de productos",
      "Base de datos en tiempo real (Supabase)",
      "Checkout integrado por transferencia",
    ],
    result: "Gestión de stock autónoma 📈"
  },
  {
    title: "TIENDA SUSHI 🍣",
    category: "E-Commerce Real",
    desc: "E-commerce desarrollado para restaurante real, con carrito dinámico, gestión de favoritos y envío de pedido directo a WhatsApp.",
    img: "tienda-sushi.webp",
    tags: ["React", "Tailwind CSS", "Vercel", "Vite"],
    repo: "https://github.com/ArielCamposs/tienda-sushi",
    link: "https://tienda-sushi.vercel.app/",
    features: [
      "Carrito de compras funcional",
      "Control visual de stock",
      "Favoritos en localStorage",
      "Integración WhatsApp API",
    ],
  },
  {
    title: "PELUQUERIA DELTA ✂️",
    category: "Landing Page",
    desc: "Landing page creada para captar clientes mediante SEO Local y CTA directo a WhatsApp.",
    img: "landing-page.webp",
    tags: ["Astro", "Tailwind CSS", "Responsive"],
    link: "https://landing-page-peluqueria-delta.vercel.app/",
    repo: "https://github.com/ArielCamposs/landing-page-informativa",
    features: [
      "SEO Local optimizado",
      "WhatsApp directo",
      "Carga ultra rapida",
    ],
    result: "Mejora notable de captacion ✨"
  },
];
---

<section id="proyectos" class="projects-section">
  <!-- Background Effects -->
  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
  <div class="bg-orb bg-orb-3"></div>
  <div class="deco-line deco-line-1"></div>
  <div class="deco-line deco-line-2"></div>

  <div class="container">
    <!-- Header -->
    <header class="section-header">
      <span class="code-tag">// SELECTED_WORKS</span>
      <h2 class="section-title">
        MIS <br/>
        <span class="gradient-text">PROYECTOS</span>
      </h2>
      <p class="section-subtitle">Proyectos reales que demuestran mis habilidades</p>
    </header>

    <!-- Projects List -->
    <div class="projects-list">
      {projects.map((project, index) => (
        <article class="project-card" data-index={index}>
          <div class={`card-layout ${index % 2 === 1 ? 'card-layout--flip' : ''}`}>

            <!-- Image Side -->
            <div class="card-media">
              <div class="card-img-wrap">
                <img
                  src={project.img}
                  alt={project.title}
                  loading="lazy"
                  class={project.objectFit ? 'img-contain' : 'img-cover'}
                />
              </div>
              <div class="card-media-fade"></div>
              <span class="card-badge">{project.category}</span>
              <div class="card-hover-links">
                <a href={project.link} target="_blank" class="hover-link hover-link--primary" title={project.ctaText || "Ver Demo"}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
                {project.repo && (
                  <a href={project.repo} target="_blank" class="hover-link hover-link--ghost" title="Ver Codigo">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  </a>
                )}
              </div>
            </div>

            <!-- Content Side -->
            <div class="card-content">
              <div class="card-content-inner">
                <div class="card-meta">
                  <span class="card-num">0{index + 1}</span>
                  <span class="card-category-text">{project.category}</span>
                </div>

                <h3 class="card-title">{project.title}</h3>
                <p class="card-desc">{project.desc}</p>

                {project.features && (
                  <ul class="card-features">
                    {project.features.map((feat) => (
                      <li>
                        <span class="feat-dot">✦</span>
                        {feat}
                      </li>
                    ))}
                  </ul>
                )}

                {project.result && (
                  <div class="card-result">{project.result}</div>
                )}

                <div class="card-tags">
                  {project.tags.map((tag) => (
                    <span class="card-tag">#{tag}</span>
                  ))}
                </div>

                <div class="card-cta">
                  <a href={project.link} target="_blank" class="btn-primary">
                    <span>{project.ctaText || "Ver Demo"}</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                  {project.repo && (
                    <a href={project.repo} target="_blank" class="btn-ghost">Codigo</a>
                  )}
                </div>
              </div>
            </div>

          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- Infinite Scroll Marquee -->
<div class="marquee-container">
  <div class="marquee">
    <div class="track">
      <p>Desarrollador Web Full Stack Junior Disponible 🚀</p>
      <p>Contrataciones &amp; Proyectos Freelance 📩</p>
      <p>React &bull; Astro &bull; Tailwind &bull; APIs &bull; UX/UI 🎨</p>
      <p>Chile | Remoto LATAM 🌍</p>
      <p>Desarrollador Web Full Stack Junior Disponible 🚀</p>
      <p>Contrataciones &amp; Proyectos Freelance 📩</p>
      <p>React &bull; Astro &bull; Tailwind &bull; APIs &bull; UX/UI 🎨</p>
      <p>Chile | Remoto LATAM 🌍</p>
    </div>
  </div>
</div>

<style>
  /* ===== SECTION ===== */
  .projects-section {
    position: relative;
    padding: 8rem 0 6rem;
    background: #0a0a0a;
    overflow: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 10;
  }

  /* ===== BACKGROUND ORBS ===== */
  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    opacity: 0.35;
  }
  .bg-orb-1 {
    top: -80px; right: -80px;
    width: 480px; height: 480px;
    background: linear-gradient(135deg, #5a8a9a, #6b4f7c);
    animation: float-orb 8s ease-in-out infinite;
  }
  .bg-orb-2 {
    bottom: 15%; left: -120px;
    width: 380px; height: 380px;
    background: linear-gradient(135deg, #c25d85, #b8996f);
    animation: float-orb 11s ease-in-out infinite reverse;
  }
  .bg-orb-3 {
    top: 50%; right: 8%;
    width: 280px; height: 280px;
    background: #b8996f;
    opacity: 0.12;
    animation: float-orb 6s ease-in-out infinite;
  }
  @keyframes float-orb {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(25px, -25px) scale(1.08); }
  }

  .deco-line {
    position: absolute;
    background: linear-gradient(90deg, transparent, #b8996f, transparent);
    height: 1px;
    pointer-events: none;
    left: 0; width: 100%;
  }
  .deco-line-1 { top: 12%; opacity: 0.18; }
  .deco-line-2 { bottom: 22%; opacity: 0.12; }

  /* ===== HEADER ===== */
  .section-header {
    margin-bottom: 5rem;
    text-align: center;
  }
  .code-tag {
    display: inline-block;
    font-family: monospace;
    font-size: 0.95rem;
    color: #b8996f;
    letter-spacing: 0.2em;
    margin-bottom: 1rem;
    text-shadow: 0 0 20px rgba(184,153,111,0.3);
  }
  .section-title {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 900;
    color: white;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.02em;
  }
  .gradient-text {
    background: linear-gradient(135deg, #c25d85 0%, #6b4f7c 50%, #5a8a9a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .section-subtitle {
    margin-top: 1.5rem;
    font-size: 1.1rem;
    color: rgba(255,255,255,0.55);
    font-weight: 300;
  }

  /* ===== PROJECTS LIST ===== */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ===== SCROLL REVEAL ===== */
  .project-card {
    opacity: 0;
    transform: translateY(56px);
    transition: opacity 0.75s ease, transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .project-card.is-visible {
    opacity: 1;
    transform: none;
  }

  /* ===== CARD LAYOUT ===== */
  .card-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 420px;
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(145deg, rgba(22,22,22,0.92), rgba(10,10,10,0.97));
    border: 1px solid rgba(255,255,255,0.07);
    transition: border-color 0.4s ease, box-shadow 0.4s ease, transform 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .card-layout:hover {
    border-color: rgba(184,153,111,0.28);
    box-shadow: 0 30px 70px rgba(0,0,0,0.45), 0 0 50px rgba(184,153,111,0.07);
    transform: translateY(-5px);
  }

  .card-layout--flip .card-media  { order: 2; }
  .card-layout--flip .card-content { order: 1; }

  /* ===== CARD MEDIA ===== */
  .card-media {
    position: relative;
    overflow: hidden;
  }
  .card-img-wrap {
    width: 100%;
    height: 100%;
  }
  .card-img-wrap img {
    width: 100%;
    height: 100%;
    transition: transform 0.7s cubic-bezier(0.4,0,0.2,1);
    display: block;
  }
  .img-cover  { object-fit: cover; }
  .img-contain {
    object-fit: contain;
    background: rgba(255,255,255,0.035);
    padding: 1rem;
  }
  .card-layout:hover .card-img-wrap img {
    transform: scale(1.04);
  }

  .card-media-fade {
    display: none;
  }

  .card-badge {
    position: absolute;
    top: 1.1rem;
    left: 1.1rem;
    padding: 0.4rem 0.9rem;
    background: linear-gradient(135deg, #c25d85, #6b4f7c);
    color: white;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-radius: 50px;
    z-index: 5;
    box-shadow: 0 4px 12px rgba(107,79,124,0.35);
  }

  .card-hover-links {
    position: absolute;
    bottom: 1.1rem;
    right: 1.1rem;
    display: flex;
    gap: 0.5rem;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    z-index: 5;
  }
  .card-layout:hover .card-hover-links {
    opacity: 1;
    transform: translateY(0);
  }
  .hover-link {
    width: 40px; height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-decoration: none;
  }
  .hover-link--primary {
    background: #b8996f;
    color: #0a0a0a;
  }
  .hover-link--ghost {
    background: rgba(255,255,255,0.18);
    color: white;
    border: 1px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(8px);
  }
  .hover-link:hover {
    transform: scale(1.12);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  /* ===== CARD CONTENT ===== */
  .card-content {
    display: flex;
    align-items: center;
    padding: 2.5rem;
  }
  .card-content-inner {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .card-num {
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: #b8996f;
    letter-spacing: 0.08em;
  }
  .card-category-text {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .card-title {
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    font-weight: 800;
    color: white;
    line-height: 1.15;
    transition: color 0.3s ease;
    margin: 0;
  }
  .card-layout:hover .card-title { color: #b8996f; }

  .card-desc {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.75;
    margin: 0;
  }

  .card-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .card-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.58);
  }
  .feat-dot { color: #b8996f; font-size: 0.58rem; flex-shrink: 0; }

  .card-result {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: linear-gradient(135deg, rgba(184,153,111,0.12), rgba(90,138,154,0.08));
    border: 1px solid rgba(184,153,111,0.28);
    border-radius: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #b8996f;
    width: fit-content;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .card-tag {
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(255,255,255,0.45);
    padding: 0.3rem 0.7rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color 0.25s, border-color 0.25s, background 0.25s;
  }
  .card-tag:hover {
    color: #5a8a9a;
    border-color: rgba(90,138,154,0.5);
    background: rgba(90,138,154,0.08);
  }

  .card-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: linear-gradient(135deg, #b8996f, #9a8159);
    color: #0a0a0a;
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 4px 14px rgba(184,153,111,0.3);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(184,153,111,0.5);
  }
  .btn-primary svg { transition: transform 0.25s ease; }
  .btn-primary:hover svg { transform: translateX(4px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: rgba(255,255,255,0.8);
    font-size: 0.85rem;
    font-weight: 600;
    border: 1.5px solid rgba(255,255,255,0.22);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s, color 0.25s;
  }
  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.6);
    background: rgba(255,255,255,0.07);
    color: white;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .card-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .card-media { height: 260px; order: 0 !important; }
    .card-content { order: 1 !important; padding: 2rem 1.75rem; }
    .card-layout:not(.card-layout--flip) .card-media-fade,
    .card-layout--flip .card-media-fade {
      background: linear-gradient(to bottom, transparent 50%, rgba(10,10,10,0.9));
    }
  }

  @media (max-width: 480px) {
    .card-content { padding: 1.5rem; }
    .card-title { font-size: 1.3rem; }
  }

  /* ===== MARQUEE ===== */
  .marquee-container {
    width: 100%;
    overflow: hidden;
    border-top: 2px solid #b8996f;
    border-bottom: 2px solid #b8996f;
    background: #0a0a0a;
    margin-top: 5rem;
  }
  .marquee {
    position: relative;
    width: 100%;
    height: 48px;
    overflow: hidden;
    white-space: nowrap;
  }
  .track {
    display: inline-flex;
    gap: 3rem;
    padding: 0.75rem 0;
    animation: marquee-move 20s linear infinite;
  }
  .track p {
    font-size: 0.85rem;
    font-weight: 700;
    color: #b8996f;
    text-transform: uppercase;
    text-shadow: 0 0 10px rgba(184,153,111,0.3);
  }
  @keyframes marquee-move {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .marquee-container:hover .track {
    animation-play-state: paused;
  }
</style>

<script>
  // Scroll Reveal
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );

  document.querySelectorAll('.project-card').forEach((card) => {
    revealObserver.observe(card);
  });

  // Magnetic CTA buttons
  document.querySelectorAll('.btn-primary').forEach((btn) => {
    btn.addEventListener('mousemove', (e: any) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      (btn as HTMLElement).style.transform = `translateY(-2px) translate(${x * 0.15}px, ${y * 0.15}px)`;
    });
    btn.addEventListener('mouseleave', () => {
      (btn as HTMLElement).style.transform = '';
    });
  });
</script>
