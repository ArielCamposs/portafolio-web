    padding: 2rem 2.2rem 2.4rem;
    background: var(--bg-secondary);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background-color 0.4s ease;
    border-top: 1px solid var(--border);
  }

  .project-card-client {
    font-family: var(--font-geist);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--violet);
    width: fit-content;
    padding: 0.35rem 0.65rem;
    border: 1px solid rgba(161, 153, 255, 0.35);
    border-radius: 999px;
    margin-bottom: 0.35rem;
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 0.85;
    transition: color 0.4s ease;
  }

  .project-card-desc {
    font-family: var(--font-playfair);
    font-style: italic;
    font-size: clamp(1rem, 1.8vw, 1.3rem);
    color: var(--text-primary);
    opacity: 0.7;
    margin: 0;
    transition: color 0.4s ease;
  }

  .project-card-badge-link {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    z-index: 10;
  }

  .project-card-badge {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    background: var(--text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .project-card-badge-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform-origin: center;
  }

  .project-card-badge-text {
    font-family: var(--font-geist);
    font-size: 7.5px;
    font-weight: 700;
    fill: var(--bg-primary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: fill 0.4s ease;
  }

  .project-card-badge-icon {
    width: 22px;
    height: 22px;
    color: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transition: color 0.4s ease, transform 0.3s ease;
  }

  .project-card-badge-icon svg {
    width: 100%;
    height: 100%;
  }

  .project-card:hover .project-card-badge {
    transform: scale(1.1);
  }

  .project-card-badge:hover .project-card-badge-icon {
    transform: scale(1.15) rotate(15deg);
  }

