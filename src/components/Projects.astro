      "Encuestas anónimas de clima de aula",
      "Asistente con Inteligencia Artificial",
    ],
    result: "92% de adopción docente 🚀",
  },
  {
    title: "NITIV.CL",
    category: "Landing Corporativa",
    desc: "Landing page de la plataforma Nitiv, diseñada para colegios chilenos.",
    img: "/images/nitiv-landing.png",
