  },
  {
    title: "TIENDA TEXTIL",
    category: "E-Commerce Textil",
    desc: "Tienda online de textilería artesanal con carrito dinámico y panel de administración.",
    img: "/images/pura-lana.png",
    tags: ["HTML5", "CSS3", "JavaScript", "Supabase"],
    link: "https://landingpage-puralana.vercel.app/",
    features: [
      "Carrito de compras dinámico",
      "Panel de administración de productos",
      "Base de datos Supabase integrada",
      "Envío de detalles de compra",
