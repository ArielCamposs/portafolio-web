---

<section class="projects-section" id="proyectos">
  <!-- Contenedor sticky que se fija en pantalla mientras el usuario scrollea -->
  <div class="projects-sticky">
    <!-- Encabezado de Proyectos -->
    <div class="projects-header">
      <h2 class="projects-title">
        <span class="projects-italic">Mis</span>
        <span class="projects-main">PROYECTOS</span>
      </h2>
      <!-- Badge circular giratoria -->
      <div class="view-all-circle" id="viewAllBadge">
        <div class="view-all-inner">
          <svg class="view-all-svg" viewBox="0 0 100 100">
            <defs>
              <path
                id="viewAllCirclePath"
                d="M 50,50 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0"></path>
            </defs>
            <text class="view-all-text">
              <textPath href="#viewAllCirclePath"
                >VER PROYECTOS • VER PROYECTOS •</textPath
              >
            </text>
          </svg>
          <div class="view-all-icon">↗</div>
        </div>
      </div>
    </div>

    <!-- Carrusel de tarjetas de proyectos -->
    <div class="projects-carousel-wrapper">
      <div class="projects-carousel" id="projectsCarousel">
        {
          projects.map((project, index) => (
            <div
              class="project-card open-drawer-trigger"
              data-project-index={index}
            >
              <div class="project-card-image">
                <img src={project.img} alt={project.title} loading="lazy" />
                <div class="project-card-overlay">
                  <span class="project-card-view">VER DETALLES</span>
                </div>
              </div>
              <div class="project-card-info">
                <h3 class="project-card-title">{project.title}</h3>
                <p class="project-card-desc">{project.category}</p>
                
                <!-- Badge circular interactivo -->
                {project.link && (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-card-badge-link"
                    onclick="event.stopPropagation()"
                  >
                    <div class="project-card-badge">
                      <svg class="project-card-badge-svg" viewBox="0 0 100 100">
                        <path
                          id={`badgePath-${index}`}
                          d="M 50,50 m -35,0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0"
                          fill="none"
                        ></path>
                        <text class="project-card-badge-text">
                          <textPath href={`#badgePath-${index}`}>
                            VER SITIO WEB • VER SITIO WEB •
                          </textPath>
                        </text>
                      </svg>
                      <div class="project-card-badge-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10"></circle>
                          <line x1="2" y1="12" x2="22" y2="12"></line>
                          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        </svg>
                      </div>
                    </div>
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script define:vars={{ projects }}>
  window.addEventListener("loaderComplete", () => {
    // Abrir drawer al hacer clic en tarjeta
    const cards = document.querySelectorAll(".project-card");
    cards.forEach((card) => {
      const index = parseInt(card.getAttribute("data-project-index") || "0");
      const data = projects[index];

      card.addEventListener("click", (e) => {
        if (e.target.closest(".project-card-badge-link")) return;
        e.preventDefault();
        window.dispatchEvent(
          new CustomEvent("open-project-drawer", { detail: data }),
        );
      });
    });

    // Zoom inverso con GSAP
    const imgs = document.querySelectorAll(".project-card-image img");
    imgs.forEach((img) => {
      // @ts-ignore
      gsap.set(img, { scale: 1.1 });
      const card = img.closest(".project-card");
      if (!card) return;
      card.addEventListener("mouseenter", () => {
        // @ts-ignore
        gsap.to(img, { scale: 1, duration: 0.7, ease: "power3.out" });
      });
      card.addEventListener("mouseleave", () => {
        // @ts-ignore
        gsap.to(img, { scale: 1.1, duration: 0.5, ease: "power2.inOut" });
      });
    });

    // Rotar badge principal del header
    const badge = document.getElementById("viewAllBadge");
    if (badge) {
      let rot = 0;
      function rotateBadge() {
        rot += 0.4;
        const svg = badge.querySelector(".view-all-svg");
        if (svg) svg.style.transform = `rotate(${rot}deg)`;
        requestAnimationFrame(rotateBadge);
      }
      rotateBadge();
    }

    // ---- Scroll horizontal con GSAP ScrollTrigger (conectado a Lenis en Layout.astro) ----
    function setupHorizontalScroll() {
      if (window.innerWidth <= 768) return;
      if (typeof gsap === "undefined" || typeof ScrollTrigger === "undefined") return;

      var section = document.getElementById("proyectos");
      var sticky = section && section.querySelector(".projects-sticky");
      var carousel = document.getElementById("projectsCarousel");
      if (!section || !sticky || !carousel) return;

      // Registrar plugin (es seguro llamarlo varias veces)
      gsap.registerPlugin(ScrollTrigger);

      // Calcular cuánto debe moverse el carrusel
      var totalMove = carousel.scrollWidth - window.innerWidth;
      if (totalMove <= 0) return;

      // Animar el translateX del carrusel vinculado al scroll de la página
      gsap.to(carousel, {
        x: -totalMove,
        ease: "none",
        scrollTrigger: {
          trigger: section,
          start: "top top",
          end: "+=" + totalMove,
          pin: sticky,
          pinSpacing: true,
          scrub: 1.5,           // Número = segundos de lag suave (efecto lerp/rubber band)
          anticipatePin: 1,
          invalidateOnRefresh: true,
          onRefresh: function() {
            totalMove = carousel.scrollWidth - window.innerWidth;
          }
        }
      });

      // Refrescar después de que ScrollTrigger calcule posiciones
      ScrollTrigger.refresh();
    }

    // Esperar a que Lenis y el DOM estén completamente listos
    setTimeout(setupHorizontalScroll, 400);

    // Rotación de los badges en cada tarjeta
    const cardBadges = document.querySelectorAll(".project-card-badge");
    if (cardBadges.length > 0) {
      const badgeRotations = Array.from(cardBadges).map(() => 0);
      const badgeHoverStates = Array.from(cardBadges).map(() => false);

      cardBadges.forEach((b, i) => {
        const card = b.closest(".project-card");
        if (card) {
          card.addEventListener("mouseenter", () => {
            badgeHoverStates[i] = true;
          });
          card.addEventListener("mouseleave", () => {
            badgeHoverStates[i] = false;
          });
        }
      });

      function animateCardBadges() {
        cardBadges.forEach((b, i) => {
          const svg = b.querySelector(".project-card-badge-svg");
          if (svg) {
            const speed = badgeHoverStates[i] ? 1.5 : 0.4;
            badgeRotations[i] = (badgeRotations[i] + speed) % 360;
            // @ts-ignore
            svg.style.transform = `rotate(${badgeRotations[i]}deg)`;
          }
        });
        requestAnimationFrame(animateCardBadges);
      }
      animateCardBadges();
    }
  });
</script>

<style>
  .projects-section {
    background: var(--bg-primary);
    transition: background-color 0.4s ease;
    width: 100%;
    padding: 3.5rem 0 2.5rem; /* Solo en mobile; desktop lo sobreescribe */
  }

  /* ScrollTrigger pina este elemento automáticamente */
  .projects-sticky {
    background: var(--bg-primary);
    transition: background-color 0.4s ease;
    width: 100%;
    padding: 0; /* El padding lo lleva projects-section en mobile */
  }

  @media (min-width: 769px) {
    .projects-section {
      padding: 0;
    }
    .projects-sticky {
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 0 3rem;
    }
  }

  .projects-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 auto 1.5rem auto;
    max-width: 100%;
    padding: 0 max(2rem, calc((100vw - 1400px) / 2 + 2rem));
    gap: 2rem;
    width: 100%;
  }

  .projects-title {
    display: flex;
    flex-direction: column;
    gap: 0em;
    margin: 0;
    flex-grow: 1;
  }

  .projects-italic {
    font-family: var(--font-playfair);
    font-style: italic;
    font-size: clamp(3.5rem, 10vw, 7.5rem);
    font-weight: 700;
    color: var(--text-primary);
    opacity: 0.7;
    display: block;
    line-height: 1;
  }

  .projects-main {
    font-family: var(--font-display);
    font-size: clamp(5.5rem, 21vw, 15.5rem);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.82;
    display: block;
    transition: color 0.4s ease;
  }

  @media (max-width: 768px) {
    .projects-header {
      /* En mobile: título a la izquierda, badge a la derecha en la misma fila */
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      padding-right: 2rem;
      margin-bottom: 1rem;
    }

    .view-all-circle {
      width: 64px;      /* Más pequeño en mobile */
      height: 64px;
      flex-shrink: 0;
    }

    .view-all-icon {
      font-size: 1.1rem;
    }

    .projects-italic {
      font-size: clamp(2.2rem, 8vw, 3.5rem);
    }

    .projects-main {
      font-size: clamp(4rem, 17vw, 6rem);
    }
  }

  /* Badge circular del header */
  .view-all-circle {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    position: relative;
    cursor: none;
  }

  .view-all-inner {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .view-all-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .view-all-text {
    font-family: var(--font-geist);
    font-size: 10px;
    font-weight: 500;
    fill: var(--text-primary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .view-all-icon {
    font-size: 1.8rem;
    color: var(--text-primary);
    font-weight: 900;
    z-index: 1;
    transition: color 0.4s ease;
  }

  /* Carrusel horizontal */
  .projects-carousel-wrapper {
    width: 100%;
    overflow: hidden;
  }

  .projects-carousel {
    display: flex;
    gap: 3.5rem;
    padding: 1rem 0;
    width: max-content;   /* ancho natural de todas las tarjetas */
    padding-left: max(2rem, calc((100vw - 1400px) / 2 + 2rem));
    padding-right: max(2rem, calc((100vw - 1400px) / 2 + 2rem));
    user-select: none;
    will-change: transform;
  }

  @media (max-width: 768px) {
    .projects-carousel-wrapper {
      overflow-x: auto;
      overflow-y: visible;
      scrollbar-width: none;
    }
    .projects-carousel-wrapper::-webkit-scrollbar {
      display: none;
    }
    .projects-carousel {
      width: max-content;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      cursor: grab;
      will-change: auto;
      gap: 1.5rem;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
      padding-top: 0.5rem;
      padding-bottom: 1rem;
    }
    .project-card {
      flex: 0 0 clamp(260px, 78vw, 400px); /* Más compactas en mobile */
    }
  }

  .projects-carousel::-webkit-scrollbar {
    display: none; /* Oculta scrollbar Chrome/Safari */
  }

  .projects-carousel.active {
    cursor: grabbing;
  }

  /* Tarjetas del proyecto */
  .project-card {
    flex: 0 0 clamp(290px, 85vw, 620px);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    cursor: none;
    position: relative;
    background: var(--bg-secondary);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
  }

  [data-theme="dark"] .project-card {
    background: var(--bg-secondary);
    border-color: var(--border);
  }

  .project-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .project-card-image {
    width: 100%;
    aspect-ratio: 16/9.5;
    overflow: hidden;
    position: relative;
    background: var(--accent);
  }

  .project-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .project-card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .project-card:hover .project-card-overlay {
    opacity: 1;
  }

  .project-card-view {
    color: #fff;
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 900;
    letter-spacing: 0.05em;
  }

  .project-card-info {
    padding: 2.2rem;
    background: var(--bg-secondary);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: background-color 0.4s ease;
    border-top: 1px solid var(--border);
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4.8rem);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 0.85;
    transition: color 0.4s ease;
  }

  .project-card-desc {
    font-family: var(--font-playfair);
    font-style: italic;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    color: var(--text-primary);
    opacity: 0.7;
    margin: 0;
    transition: color 0.4s ease;
  }

  /* Badge circular interactivo en tarjeta */
  .project-card-badge-link {
    position: absolute;
    bottom: 2rem;
    right: 2rem;
    z-index: 10;
  }

  .project-card-badge {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    background: var(--text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .project-card-badge-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform-origin: center;
  }

  .project-card-badge-text {
    font-family: var(--font-geist);
    font-size: 7.5px;
    font-weight: 700;
    fill: var(--bg-primary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: fill 0.4s ease;
  }

  .project-card-badge-icon {
    width: 22px;
    height: 22px;
    color: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transition: color 0.4s ease, transform 0.3s ease;
  }

  .project-card-badge-icon svg {
    width: 100%;
    height: 100%;
  }

  /* Hover del badge */
  .project-card:hover .project-card-badge {
    transform: scale(1.1);
  }

  .project-card-badge:hover .project-card-badge-icon {
    transform: scale(1.15) rotate(15deg);
  }
</style>
