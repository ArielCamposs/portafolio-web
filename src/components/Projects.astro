---

<section class="projects-section" id="proyectos">
  <div class="projects-inner">
    <div class="projects-header">
      <h2 class="projects-title">
        <span class="projects-italic">Mis</span>
        <span class="projects-main">PROYECTOS</span>
      </h2>
      <div class="view-all-circle" id="viewAllBadge">
        <div class="view-all-inner">
          <svg class="view-all-svg" viewBox="0 0 100 100">
            <defs>
              <path
                id="viewAllCirclePath"
                d="M 50,50 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0"></path>
            </defs>
            <text class="view-all-text">
              <textPath href="#viewAllCirclePath"
                >VER PROYECTOS • VER PROYECTOS •</textPath
              >
            </text>
          </svg>
          <div class="view-all-icon">↗</div>
        </div>
      </div>
    </div>

    <!-- Grid Desktop -->
    <div class="projects-grid is-desktop" data-reveal="fade-up" data-reveal-stagger="0.12">
      {
        projects.map((project, index) => (
          <div
            class:list={[
              "project-card open-drawer-trigger",
              { "project-card--portrait": project.portrait },
            ]}
            data-project-index={index}
          >
            <div
              class:list={[
                "project-card-image skeleton-wrapper",
                { "project-card-image--portrait": project.portrait },
              ]}
            >
              <img src={project.img} alt={project.title} loading="lazy" />
              <div class="skeleton-placeholder"></div>
            </div>
            <div class="project-card-info">
              {
                project.client && (
                  <span class="project-card-client">{project.client}</span>
                )
              }
              <h3 class="project-card-title">{project.title}</h3>
              <h3 class="project-card-title">{project.title}</h3>
              <p class="project-card-desc">{project.category}</p>

              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-card-badge-link"
                  onclick="event.stopPropagation()"
                >
                  <div class="project-card-badge">
                    <svg class="project-card-badge-svg" viewBox="0 0 100 100">
                      <path
                        id={`badgePath-${index}`}
                        d="M 50,50 m -35,0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0"
                        fill="none"
                      ></path>
                      <text class="project-card-badge-text">
                        <textPath href={`#badgePath-${index}`}>
                          VER SITIO WEB • VER SITIO WEB •
                        </textPath>
                      </text>
                    </svg>
                    <div class="project-card-badge-icon">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="2" y1="12" x2="22" y2="12"></line>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                        ></path>
                      </svg>
                    </div>
                  </div>
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Swiper Móvil -->
    <div class="swiper projects-swiper is-mobile" data-reveal="fade-up">
      <div class="swiper-wrapper">
        {
          projects.map((project, index) => (
            <div class="swiper-slide">
              <div
                class:list={[
                  "project-card open-drawer-trigger",
                  { "project-card--portrait": project.portrait },
                ]}
                data-project-index={index}
              >
                <div
                  class:list={[
                    "project-card-image skeleton-wrapper",
                    { "project-card-image--portrait": project.portrait },
                  ]}
                >
                  <img src={project.img} alt={project.title} loading="lazy" />
                  <div class="skeleton-placeholder"></div>
                </div>
                <div class="project-card-info">
                  {
                    project.client && (
                      <span class="project-card-client">{project.client}</span>
                    )
                  }
                  <h3 class="project-card-title">{project.title}</h3>
                  <p class="project-card-desc">{project.category}</p>

                  {project.link && (
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="project-card-badge-link"
                      onclick="event.stopPropagation()"
                    >
                      <div class="project-card-badge">
                        <svg class="project-card-badge-svg" viewBox="0 0 100 100">
                          <path
                            id={`swiperBadgePath-${index}`}
                            d="M 50,50 m -35,0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0"
                            fill="none"
                          ></path>
                          <text class="project-card-badge-text">
                            <textPath href={`#swiperBadgePath-${index}`}>
                              VER SITIO WEB • VER SITIO WEB •
                            </textPath>
                          </text>
                        </svg>
                        <div class="project-card-badge-icon">
                          <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="2" y1="12" x2="22" y2="12"></line>
                            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
                            ></path>
                          </svg>
                        </div>
                      </div>
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
      <!-- Paginación -->
      <div class="swiper-pagination projects-swiper-pagination"></div>
    </div>

    <!-- Indicador de swipe en móvil -->
    <div class="swipe-hint is-mobile" aria-hidden="true">
      <span class="swipe-hint-text">Desliza para ver más</span>
      <svg class="swipe-hint-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </div>
  </div>
</section>

<script define:vars={{ projects }}>
  window.addEventListener("loaderComplete", () => {
    // --- Inicializar Swiper en móvil ---
    const isMobile = window.innerWidth <= 768;
    let swiperInstance = null;

    function initSwiper() {
      const swiperEl = document.querySelector(".projects-swiper");
      if (!swiperEl) return;

      // @ts-ignore
      if (typeof Swiper !== "undefined") {
        // @ts-ignore
        swiperInstance = new Swiper(swiperEl, {
          slidesPerView: 1.15,
          centeredSlides: true,
          spaceBetween: 16,
          grabCursor: true,
          touchRatio: 1.2,
          speed: 400,
          pagination: {
            el: ".projects-swiper-pagination",
            clickable: true,
            dynamicBullets: true,
          },
          breakpoints: {
            480: {
              slidesPerView: 1.4,
              spaceBetween: 20,
            },
          },
          on: {
            slideChange: function () {
              // Ocultar hint después del primer swipe
              const hint = document.querySelector(".swipe-hint");
              if (hint && this.activeIndex > 0) {
                hint.classList.add("swipe-hint--hidden");
              }
            },
          },
        });

        // Animar badges del swiper
        animateSwiperBadges();
      }
    }

    // Animación de badges dentro del swiper
    function animateSwiperBadges() {
      const badges = document.querySelectorAll(".projects-swiper .project-card-badge");
      if (badges.length === 0) return;

      const rotations = Array.from(badges).map(() => 0);

      function rotate() {
        badges.forEach((b, i) => {
          const svg = b.querySelector(".project-card-badge-svg");
          if (svg) {
            rotations[i] = (rotations[i] + 0.5) % 360;
            svg.style.transform = `rotate(${rotations[i]}deg)`;
          }
        });
        requestAnimationFrame(rotate);
      }
      rotate();
    }

    // --- Click handlers (compartidos entre grid y swiper) ---
    function initCardClicks() {
      const cards = document.querySelectorAll(".project-card");
      cards.forEach((card) => {
        const index = parseInt(card.getAttribute("data-project-index") || "0");
        const data = projects[index];

        card.addEventListener("click", (e) => {
          if (e.target.closest(".project-card-badge-link")) return;
          e.preventDefault();
          window.dispatchEvent(
            new CustomEvent("open-project-drawer", { detail: data }),
          );
        });
      });
    }

    // --- Badge de "VER PROYECTOS" (rotación) ---
    function initViewAllBadge() {
      const badge = document.getElementById("viewAllBadge");
      if (badge) {
        let rot = 0;
        function rotateBadge() {
          rot += 0.4;
          const svg = badge.querySelector(".view-all-svg");
          if (svg) svg.style.transform = `rotate(${rot}deg)`;
          requestAnimationFrame(rotateBadge);
        }
        rotateBadge();
      }
    }

    // --- Badges de cards desktop (rotación con hover) ---
    function initCardBadges() {
      const cardBadges = document.querySelectorAll(".projects-grid .project-card-badge");
      if (cardBadges.length > 0) {
        const badgeRotations = Array.from(cardBadges).map(() => 0);
        const badgeHoverStates = Array.from(cardBadges).map(() => false);

        cardBadges.forEach((b, i) => {
          const card = b.closest(".project-card");
          if (card) {
            card.addEventListener("mouseenter", () => {
              badgeHoverStates[i] = true;
            });
            card.addEventListener("mouseleave", () => {
              badgeHoverStates[i] = false;
            });
          }
        });

        function animateCardBadges() {
          cardBadges.forEach((b, i) => {
            const svg = b.querySelector(".project-card-badge-svg");
            if (svg) {
              const speed = badgeHoverStates[i] ? 1.5 : 0.4;
              badgeRotations[i] = (badgeRotations[i] + speed) % 360;
              svg.style.transform = `rotate(${badgeRotations[i]}deg)`;
            }
          });
          requestAnimationFrame(animateCardBadges);
        }
        animateCardBadges();
      }
    }

    // --- Inicializar todo ---
    initCardClicks();
    initViewAllBadge();
    initCardBadges();

    if (isMobile) {
      // Cargar Swiper dinámicamente para no bloquear el build
      if (typeof Swiper === "undefined") {
        // Cargar CSS de Swiper
        const link = document.createElement("link");
        link.rel = "stylesheet";
        link.href = "https://cdn.jsdelivr.net/npm/swiper@12.0.3/swiper-bundle.min.css";
        document.head.appendChild(link);

        // Cargar JS de Swiper
        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/swiper@12.0.3/swiper-bundle.min.js";
        script.onload = initSwiper;
        document.body.appendChild(script);
      } else {
        initSwiper();
      }
    }

    // Re-inicializar Swiper al cambiar tamaño de pantalla
    let resizeTimeout;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const nowMobile = window.innerWidth <= 768;
        if (nowMobile && !swiperInstance) {
          // Cambió a móvil — iniciar swiper
          if (typeof Swiper !== "undefined") {
            initSwiper();
          }
        } else if (!nowMobile && swiperInstance) {
          // Cambió a desktop — destruir swiper
          swiperInstance.destroy(true, true);
          swiperInstance = null;
        }
      }, 300);
    });
  });
</script>

<style>
  .projects-section {
    background: var(--bg-primary);
    transition: background-color 0.4s ease;
    width: 100%;
    padding: 4rem 0 5rem;
  }

  .projects-inner {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 max(1.5rem, calc((100vw - 1400px) / 2 + 1.5rem));
  }

  .projects-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin: 0 0 2.5rem 0;
    gap: 2rem;
    width: 100%;
  }

  .projects-title {
    display: flex;
    flex-direction: column;
    gap: 0em;
    margin: 0;
    flex-grow: 1;
  }

  .projects-italic {
    font-family: var(--font-playfair);
    font-style: italic;
    font-size: clamp(3.5rem, 10vw, 7.5rem);
    font-weight: 700;
    color: var(--text-primary);
    opacity: 0.7;
    display: block;
    line-height: 1;
  }

  .projects-main {
    font-family: var(--font-display);
    font-size: clamp(5.5rem, 21vw, 15.5rem);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.82;
    display: block;
    transition: color 0.4s ease;
  }

  @media (max-width: 768px) {
    .projects-section {
      padding: 3rem 0 3.5rem;
    }

    .projects-header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.75rem;
    }

    .view-all-circle {
      width: 64px;
      height: 64px;
      flex-shrink: 0;
    }

    .view-all-icon {
      font-size: 1.1rem;
    }

    .projects-italic {
      font-size: clamp(2.2rem, 8vw, 3.5rem);
    }

    .projects-main {
      font-size: clamp(4rem, 17vw, 6rem);
    }
  }

  .view-all-circle {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    position: relative;
    cursor: none;
  }

  .view-all-inner {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .view-all-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .view-all-text {
    font-family: var(--font-geist);
    font-size: 10px;
    font-weight: 500;
    fill: var(--text-primary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .view-all-icon {
    font-size: 1.8rem;
    color: var(--text-primary);
    font-weight: 900;
    z-index: 1;
    transition: color 0.4s ease;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 2.5rem 2rem;
    width: 100%;
    align-items: start;
  }

  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .project-card {
    display: flex;
    flex-direction: column;
    cursor: none;
    position: relative;
    background: var(--bg-secondary);
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: background-color 0.4s ease, border-color 0.4s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
  }

  [data-theme="dark"] .project-card {
    background: var(--bg-secondary);
    border-color: var(--border);
  }

  .project-card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    position: relative;
    background: var(--accent);
  }

  .project-card-image--portrait {
    padding: 1rem 1.5rem;
    background: #eef1f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  [data-theme="dark"] .project-card-image--portrait {
    background: #252525;
  }

  .project-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .project-card-image--portrait img {
    width: auto;
    height: 100%;
    max-width: 38%;
    min-width: 120px;
    object-fit: contain;
    object-position: center;
  }

