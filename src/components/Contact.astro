  .contact-footer {
    width: 100%;
    max-width: 1400px;
    margin: 4rem auto 0;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
