  /* === Sección principal === */
  .contact-section {
    min-height: 100vh;
    padding: 6rem 2rem 4rem;
    background: var(--bg-primary);
    transition: background-color 0.4s ease;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
  }

  /* === Canvas de ondas === */
  .contact-waves-wrapper {
    position: relative;
    width: 100%;
    height: 220px;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .contact-wave-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* === Área principal de contacto === */
  .contact-main {
    max-width: 1400px;
    margin: auto auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    align-items: center;
    text-align: center;
    width: 100%;
    flex-grow: 1;
    justify-content: center;
  }

  .contact-title {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    width: 100%;
    align-items: center;
    text-align: center;
  }

  .contact-title-line {
    font-family: var(--font-display);
    font-size: clamp(3.8rem, 22vw, 22rem);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.82;
    display: block;
    transition: color 0.4s ease;
    width: 100%;
  }

  /* === Formulario === */
  .contact-form-area {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    width: 100%;
    max-width: 680px;
    align-items: center;
  }

  .contact-form-label {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    opacity: 0.5;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .contact-textarea-wrapper {
    width: 100%;
  }

  .contact-textarea {
    width: 100%;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-primary);
    padding: 1rem;
    font-family: var(--font-geist);
    font-size: 0.9rem;
