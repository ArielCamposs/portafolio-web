    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-primary);
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .contact-social-link:hover {
    opacity: 1;
  }

  /* === Puerta de salida === */
  .contact-exit {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
  }

  .contact-exit-text {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-family: var(--font-geist);
    font-size: clamp(0.6rem, 0.9vw, 0.75rem);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-primary);
    opacity: 0.5;
    line-height: 1.8;
    transition: color 0.4s ease;
  }

  .contact-exit-line {
    display: block;
    overflow: hidden;
  }

  .contact-exit-word {
    display: block;
  }

  .contact-door-container {
    cursor: none;
    position: relative;
    width: 55px;
  }

  .contact-door-icon {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.3s ease;
  }

  .contact-door-closed-light {
    display: block;
  }
  .contact-door-closed-dark {
    display: none;
  }

  [data-theme="dark"] .contact-door-closed-light {
    display: none;
  }
  [data-theme="dark"] .contact-door-closed-dark {
    display: block;
  }

  .contact-door-open {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .contact-door-container:hover .contact-door-closed {
    opacity: 0;
  }

  .contact-door-container:hover .contact-door-open {
    opacity: 1;
    pointer-events: auto;
  }

  #psychedelicCanvas {
    width: 100%;
    height: auto;
    display: block;
  }

  .contact-door-frame {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
