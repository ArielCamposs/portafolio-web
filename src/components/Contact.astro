<script>
  // WhatsApp con mensaje personalizado
  function setupWhatsApp() {
    const btn = document.getElementById(
      "wa-button",
    ) as HTMLAnchorElement | null;
    const msg = document.getElementById(
      "wa-message",
    ) as HTMLTextAreaElement | null;
    if (!btn || !msg) return;

    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const text =
        msg.value.trim() ||
        "Hola Ariel! Estoy interesado en un sitio web profesional.";
      window.open(
        "https://wa.me/56931342699?text=" + encodeURIComponent(text),
        "_blank",
      );
    });
  }

  // Canvas de ondas interactivo
  function initContactWaves() {
    const canvas = document.getElementById("waveCanvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d") as CanvasRenderingContext2D;
    if (!ctx) return;

    let mouse = { x: -1000, y: -1000 };
    let targetMouse = { x: -1000, y: -1000 };
    const historyLength = 20;
    let mouseHistory: { x: number; y: number }[] = [];
    const lineCount = 16;
    const pointsPerLine = 80;
    const mouseRadius = 100;
    const mouseStrength = 22;
    const smoothing = 0.08;
    const returnSpeed = 0.03;

    let lines: { x: number; baseY: number; y: number; velocity: number }[][] =
      [];

    function resize() {
      const parent = canvas.parentElement;
      if (!parent) return;
      canvas.width = parent.offsetWidth;
      canvas.height = parent.offsetHeight;
      buildLines();
    }

    function buildLines() {
      lines = [];
      const padding = 20;
      const spacing = (canvas.height - padding * 2) / (lineCount + 1);
      for (let i = 0; i < lineCount; i++) {
        const y = padding + spacing * (i + 1);
        const pts = [];
        for (let j = 0; j <= pointsPerLine; j++) {
          const x =
            padding + (j / pointsPerLine) * (canvas.width - padding * 2);
          pts.push({ x, baseY: y, y, velocity: 0 });
        }
        lines.push(pts);
      }
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const isDark =
        document.documentElement.getAttribute("data-theme") === "dark";
      ctx.strokeStyle = isDark
        ? "rgba(230,225,221,0.2)"
        : "rgba(26,26,26,0.12)";
      ctx.lineWidth = 1.5;

      lines.forEach((pts) => {
        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        for (let i = 1; i < pts.length - 1; i++) {
          const mx = (pts[i].x + pts[i + 1].x) / 2;
          const my = (pts[i].y + pts[i + 1].y) / 2;
          ctx.quadraticCurveTo(pts[i].x, pts[i].y, mx, my);
        }
        ctx.lineTo(pts[pts.length - 1].x, pts[pts.length - 1].y);
        ctx.stroke();
      });
    }

    function update() {
      mouse.x += (targetMouse.x - mouse.x) * smoothing;
      mouse.y += (targetMouse.y - mouse.y) * smoothing;
      mouseHistory.push({ x: mouse.x, y: mouse.y });
      if (mouseHistory.length > historyLength) mouseHistory.shift();

      lines.forEach((pts) => {
        pts.forEach((pt) => {
          let disp = 0;
          mouseHistory.forEach((h, idx) => {
            const age = (historyLength - idx) / historyLength;
            const dx = h.x - pt.x;
            const dy = h.y - pt.baseY;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < mouseRadius) {
              const f = 1 - dist / mouseRadius;
              disp += f * f * f * mouseStrength * age;
            }
          });
          const ty = pt.baseY + disp;
          const diff = ty - pt.y;
          pt.velocity += diff * 0.15;
          pt.velocity *= 0.75;
          pt.y += pt.velocity;
          if (disp === 0) pt.y += (pt.baseY - pt.y) * returnSpeed;
        });
      });
    }

    let visible = false;
    let animId: number | null = null;
    function animate() {
      if (!visible) {
        animId = null;
        return;
      }
      update();
      draw();
      animId = requestAnimationFrame(animate);
    }

    resize();
    window.addEventListener("resize", resize);

    const section = document.querySelector(".contact-section");
    if (section) {
      section.addEventListener("mousemove", (e: any) => {
        const r = canvas.getBoundingClientRect();
        targetMouse.x = e.clientX - r.left;
        targetMouse.y = e.clientY - r.top;
      });
      section.addEventListener("mouseleave", () => {
        targetMouse.x = -1000;
        targetMouse.y = -1000;
      });
    }

    new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        visible = e.isIntersecting;
        if (visible && !animId) animate();
      });
    }).observe(canvas);
  }

  // Canvas psicodélico de puertas
  function initPsychedelicCanvas() {
    [
      document.getElementById("psychedelicCanvas"),
      document.getElementById("heroPsychedelicCanvas"),
    ].forEach((el) => {
      const canvas = el as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext("2d") as CanvasRenderingContext2D;
      if (!ctx) return;
      const w = canvas.width,
        h = canvas.height;
      const cx = w / 2,
        cy = h / 2;
      let rot = 0,
        visible = false,
        animId: number | null = null;

      function draw() {
        if (!visible) {
          animId = null;
          return;
        }
        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = "#1A1A1A";
        ctx.fillRect(0, 0, w, h);
        ctx.save();
        ctx.translate(cx, cy);
        rot += 0.5;
        ctx.rotate((rot * Math.PI) / 180);
        ctx.fillStyle = "rgba(161, 153, 255, 0.55)";
        const sc = (Math.max(w, h) / 1477.3) * 1.2;
        for (let i = 0; i < 36; i++) {
          ctx.save();
          ctx.rotate((i * 10 * Math.PI) / 180);
          ctx.scale(sc, sc);
          ctx.fillRect(-738, -128, 1477, 256);
          ctx.restore();
        }
        ctx.restore();
        animId = requestAnimationFrame(draw);
      }

      new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          visible = e.isIntersecting;
          if (visible && !animId) draw();
        });
      }).observe(canvas);
    });
  }

  window.addEventListener("loaderComplete", () => {
    setupWhatsApp();
    initContactWaves();
    initPsychedelicCanvas();
  });
</script>

