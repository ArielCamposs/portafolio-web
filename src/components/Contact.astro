<script>
    const setupWhatsApp = () => {
        const waButton = document.getElementById("wa-button");
        const waMessage = document.getElementById("wa-message");
        const baseUrl = "https://wa.me/56931342699?text=";
        const defaultMsg =
            "Hola Ariel! Estoy interesado en un sitio web profesional.";

        if (waButton && waMessage) {
            // Remove previous event listeners if setupWhatsApp is called multiple times
            const newButton = waButton.cloneNode(true);
            waButton.parentNode.replaceChild(newButton, waButton);

            newButton.addEventListener("click", (e) => {
                e.preventDefault();
                const userText = waMessage.value.trim();
                const textToSend = userText ? userText : defaultMsg;
                window.open(baseUrl + encodeURIComponent(textToSend), "_blank");
            });
        }
    };

    // Ejecutar en carga inicial
    setupWhatsApp();

    // Ejecutar en navegaciones de cliente de Astro (View Transitions)
    document.addEventListener("astro:page-load", setupWhatsApp);
</script>
