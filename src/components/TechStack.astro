---
const techs = [
    { name: "HTML5", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" },
    { name: "Tailwind", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg" },
    { name: "JavaScript", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" },
    { name: "Astro", icon: "https://astro.build/assets/press/astro-icon-light-gradient.svg" },
    { name: "PHP", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg" },
    { name: "GitHub", icon: "https://www.svgrepo.com/show/349375/github.svg" },
    { name: "Vercel", icon: "https://assets.vercel.com/image/upload/v1588805858/repositories/vercel/logo.png", invert: true },
    { name: "IA", icon: "https://img.icons8.com/fluency/96/artificial-intelligence.png" },
    { name: "Firebase", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/firebase/firebase-plain.svg" },
    { name: "Supabase", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/supabase/supabase-original.svg" }
];
const loop = [...techs, ...techs, ...techs, ...techs];
---

<section class="techstack-section">
  <div class="techstack-track-wrapper">
    <div class="techstack-track scroller">
      {loop.map(t => (
        <div class="tech-item">
          <img src={t.icon} alt={t.name} class={t.invert ? "tech-icon tech-icon-invert" : "tech-icon"} />
          <span class="tech-name">{t.name}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="techstack-track-wrapper">
    <div class="techstack-track scroller-reverse">
      {loop.map(t => (
        <div class="tech-item">
          <img src={t.icon} alt={t.name} class={t.invert ? "tech-icon tech-icon-invert" : "tech-icon"} />
          <span class="tech-name">{t.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .techstack-section {
    padding: 5rem 0;
    background: var(--bg-primary);
    display: flex;
    flex-direction: column;
    gap: 2rem;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background-color 0.4s ease, border-color 0.4s ease;
  }

  .techstack-track-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .techstack-track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 0;
  }

  .tech-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0 2.5rem;
    cursor: default;
    transition: transform 0.3s ease;
  }

  .tech-item:hover {
    transform: scale(1.15);
  }

  .tech-icon {
    width: 56px;
    height: 56px;
    object-fit: contain;
    display: block;
    filter: grayscale(30%);
    transition: filter 0.3s ease;
  }

  .tech-item:hover .tech-icon {
    filter: grayscale(0%);
  }

  .tech-icon-invert {
    filter: invert(1) grayscale(30%);
  }

  .tech-item:hover .tech-icon-invert {
    filter: invert(1) grayscale(0%);
  }

  .tech-name {
    font-family: var(--font-geist);
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-primary);
    opacity: 0.5;
    white-space: nowrap;
  }

  .scroller {
    animation: scrollLeft 35s linear infinite;
  }

  .scroller-reverse {
    animation: scrollRight 40s linear infinite;
  }

  .scroller:hover, .scroller-reverse:hover {
    animation-play-state: paused;
  }

  @keyframes scrollLeft {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scrollRight {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
</style>
