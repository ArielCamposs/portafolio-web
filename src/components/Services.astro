---
const services = [
  {
    title: "Páginas Web Profesionales",
    description: "Sitios web rápidos y modernos que ayudan a tu negocio a verse profesional en internet y captar nuevos clientes.",
    num: "01"
  },
  {
    title: "Tiendas Online (E-Commerce)",
    description: "Tiendas virtuales fáciles de usar para vender tus productos, con carrito de compras y pedidos directo a tu WhatsApp.",
    num: "02"
  },
  {
    title: "Sistemas a la Medida",
    description: "Programas personalizados para ordenar los datos de tu negocio, gestionar stock o automatizar tareas cotidianas.",
    num: "03"
  },
  {
    title: "Apps Móviles",
    description: "Aplicaciones para celular pensadas para uso en terreno: registro de jornadas, inventarios, reportes y gestión operativa desde cualquier lugar.",
    num: "04"
  },
  {
    title: "Mejora de Sitios Web",
    description: "Mejoramos la velocidad y diseño de tu página web actual para que funcione rápido en celulares y no pierdas visitas.",
    num: "05"
  }
];
---

<section id="servicios" class="services-section">
  <div class="services-container">
    <!-- Header -->
    <div class="services-header">
      <span class="services-tag">// LO_QUE_PUEDO_CONSTRUIR</span>
      <h2 class="services-title font-display">
        <span class="services-title-main" data-char-swap>MIS</span>
        <span class="services-title-accent" data-char-swap>SERVICIOS</span>
      </h2>
    </div>

    <!-- Lista de servicios -->
    <div class="services-list" data-reveal="fade-up" data-reveal-stagger="0.1">
      {services.map((service) => (
        <div class="service-item">
          <div class="service-left">
            <span class="service-num">{service.num}</span>
            <h3 class="service-name">{service.title}</h3>
          </div>
          <div class="service-right">
            <p class="service-desc">{service.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    position: relative;
    padding: 7rem 0 5rem;
    background: var(--bg-primary);
    transition: background-color 0.4s ease;
  }

  .services-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
  }

  .services-header {
    margin-bottom: 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .services-tag {
    display: inline-block;
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    opacity: 0.5;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .services-title {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 17vw, 15.5rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-align: center;
    width: 100%;
    margin: 0;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0 1.5rem;
  }

  .services-title-main {
    color: var(--text-primary);
    transition: color 0.4s ease;
  }

  .services-title-accent {
    color: var(--beige);
    transition: color 0.4s ease;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    width: 100%;
    border-top: 1px solid var(--border);
  }

  .service-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: border-color 0.3s ease;
  }

  .service-item:hover {
    border-color: var(--text-primary);
  }

  @media (min-width: 768px) {
    .service-item {
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
      padding: 3rem 0;
      align-items: center;
    }
  }

  .service-left {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .service-num {
    font-family: monospace;
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-primary);
    opacity: 0.2;
    transition: opacity 0.3s ease, color 0.3s ease;
    user-select: none;
    min-width: 2.5rem;
  }

  .service-item:hover .service-num {
    opacity: 0.8;
    color: var(--beige);
  }

  .service-name {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 900;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.1;
    text-transform: uppercase;
    transition: color 0.4s ease;
  }

  .service-right {
    width: 100%;
  }

  .service-desc {
    font-family: var(--font-geist);
    font-size: clamp(0.9rem, 1.8vw, 1.05rem);
    color: var(--text-primary);
    opacity: 0.6;
    line-height: 1.6;
    margin: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .service-item:hover .service-desc {
    opacity: 0.9;
    transform: translateX(8px);
  }
</style>
