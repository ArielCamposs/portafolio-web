---
const stats = [
  { label: "Proyectos", value: "3+" },
  { label: "Rendimiento", value: "98%" },
  { label: "Tecnologías", value: "10+" },
  { label: "Clean Code", value: "100%" },
];
---

<section id="sobre-mi" class="about-section">
  <!-- Header -->
  <div class="about-header">
    <span class="about-tag">// CONÓCEME</span>
    <h2 class="about-title">
      <span class="about-title-line font-display" data-char-swap>SOBRE</span>
      <span class="about-title-line about-title-accent font-display" data-char-swap>MÍ</span>
    </h2>
  </div>

  <!-- Texto biográfico gigante -->
  <h2 class="about-bio">
    HOLA. SOY ARIEL. UN ANALISTA PROGRAMADOR COMPUTACIONAL Y DESARROLLADOR WEB
    FULL-STACK EN LA LIGUA, CHILE. VIVO LA INTERESANTE VIDA DEL CÓDIGO Y DE LA
    CREACIÓN WEB.
  </h2>

  <!-- Grid de detalles -->
  <div class="about-grid">
    <!-- Foto -->
    <div class="about-photo">
      <div class="about-photo-inner">
        <img
          src="/generated-image.webp"
          alt="Ariel Campos - Desarrollador"
          class="about-img"
        />
      </div>
    </div>

    <!-- Info -->
    <div class="about-info">
      <!-- Descripción -->
      <div class="about-description">
        <p>
          Actualmente trabajo en el <strong
            >Departamento de Salud de La Ligua (DESAM) como informático</strong
          > y soy cofundador de <a
            href="https://nitiv.cl"
            target="_blank"
            rel="noopener noreferrer"
            class="about-link">Nitiv SpA.</a
          >, donde lidero el diseño y desarrollo de nuestra infraestructura web
          y aplicaciones SaaS.
        </p>
        <p>
          Me especializo en crear interfaces modernas, rápidas y orientadas a
          resultados, aplicando metodologías ágiles como <strong>SCRUM</strong> y
          principios de <strong>Clean Code</strong>.
        </p>
      </div>

      <!-- Datos rápidos -->
      <div class="about-data-card">
        <div class="about-data-row">
          <span class="about-data-label">UBICACIÓN:</span>
          <span class="about-data-value">LA LIGUA, CHILE</span>
        </div>
        <div class="about-data-row">
          <span class="about-data-label">ESTADO:</span>
          <span class="about-data-value about-available"
            >DISPONIBLE PARA PROYECTOS</span
          >
        </div>
        <div class="about-data-row">
          <span class="about-data-label">EMPRESA:</span>
          <span class="about-data-value">DESAM / NITIV SPA</span>
        </div>
      </div>

      <!-- Métricas -->
      <div class="about-stats">
        {
          stats.map((stat) => (
            <div class="about-stat">
              <span class="about-stat-label">{stat.label}</span>
              <span class="about-stat-value">{stat.value}</span>
            </div>
          ))
        }
      </div>

      <!-- Botón CV -->
      <div class="about-cv-wrapper">
        <a
          href="/curriculum.pdf"
          download="Curriculum_Vitae_Ariel_Campos.pdf"
          target="_blank"
          class="about-cv-btn"
        >
          <svg
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
            ></path>
          </svg>
          DESCARGAR CV
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 6rem 2rem 5rem;
    max-width: 1400px;
    margin: 0 auto;
    background: var(--bg-primary);
    transition: background-color 0.4s ease;
    width: 100%;
  }

  .about-header {
    margin-bottom: 4rem;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .about-tag {
    display: inline-block;
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    opacity: 0.5;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .about-title {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    width: 100%;
  }

  .about-title-line {
    font-family: var(--font-display);
    font-size: clamp(5.5rem, 21vw, 15.5rem);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    line-height: 0.82;
    letter-spacing: -0.02em;
    display: block;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), color 0.4s ease;
    width: 100%;
    transform-origin: bottom left;
    cursor: pointer;
  }

  .about-title-line:hover {
    transform: translateY(-15px) rotate(-1deg);
    color: var(--beige);
  }

  .about-title-accent {
    color: var(--beige);
  }

  .about-bio {
    font-family: var(--font-geist);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 400;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.5;
    margin-bottom: 4rem;
    opacity: 0.85;
    transition: color 0.4s ease;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 0.8fr 1.2fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .about-photo {
    width: 100%;
  }

  .about-photo-inner {
    border: 1px solid var(--border);
    overflow: hidden;
    background: var(--accent);
    transition: border-color 0.4s ease;
  }

  .about-img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
    transition:
      filter 0.6s ease,
      transform 0.6s ease;
  }

  .about-photo-inner:hover .about-img {
    filter: grayscale(0%);
    transform: scale(1.04);
  }

  .about-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .about-description {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-description p {
    font-family: var(--font-geist);
    font-size: 1rem;
    color: var(--text-primary);
    opacity: 0.7;
    line-height: 1.7;
    margin: 0;
    transition: color 0.4s ease;
  }

  .about-description strong {
    color: var(--text-primary);
    opacity: 1;
    font-weight: 700;
  }

  .about-link {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .about-link:hover {
    opacity: 0.6;
  }

  .about-data-card {
    border: 1px solid var(--border);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    transition: border-color 0.4s ease;
  }

  .about-data-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
    font-family: monospace;
    font-size: 0.8rem;
    transition: border-color 0.4s ease;
  }

  .about-data-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .about-data-label {
    color: var(--text-primary);
    opacity: 0.5;
    letter-spacing: 0.1em;
  }

  .about-data-value {
    color: var(--text-primary);
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: color 0.4s ease;
  }

  .about-available {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .about-stat {
    border: 1px solid var(--border);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.4s ease;
  }

  .about-stat-label {
    font-family: monospace;
    font-size: 0.7rem;
    color: var(--text-primary);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .about-stat-value {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
    transition: color 0.4s ease;
  }

  .about-cv-wrapper {
    margin-top: 0.5rem;
  }

  .about-cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: var(--font-geist);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    background: transparent;
    transition:
      background-color 0.3s ease,
      color 0.3s ease,
      border-color 0.4s ease;
    cursor: none;
  }

  .about-cv-btn:hover {
    background: var(--text-primary);
    color: var(--bg-primary);
    border-color: var(--text-primary);
  }

  .about-cv-btn svg {
    transition: inherit;
  }
</style>
