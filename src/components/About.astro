---
const stats = [
  { label: "Proyectos", value: "3+" },
  { label: "Rendimiento", value: "98%" },
  { label: "Tecnologías", value: "5+" },
  { label: "Optimización", value: "100%" },
];

const techStack = [
  "HTML5", "CSS3", "JavaScript", "TypeScript",
  "React", "Next.js", "Astro", "Tailwind",
  "PHP", "Node.js", "Supabase", "Firebase",
  "MySQL", "GSAP", "Zustand", "Vite",
  "Git", "GitHub", "Vercel",
];
---

<section id="sobre-mi" class="about-section">
  <!-- Header -->
  <div class="about-header">
    <span class="about-tag">// CONÓCEME</span>
    <h2 class="about-title">
      <span class="about-title-line font-display" data-char-swap>SOBRE</span>
      <span class="about-title-line about-title-accent font-display" data-char-swap>MÍ</span>
    </h2>
  </div>

  <!-- Texto biográfico gigante -->
  <h2 class="about-bio">
    HOLA. SOY ARIEL. UN ANALISTA PROGRAMADOR COMPUTACIONAL Y DESARROLLADOR WEB
    FULL-STACK EN LA LIGUA, CHILE. VIVO LA INTERESANTE VIDA DEL CÓDIGO Y DE LA
    CREACIÓN WEB.
  </h2>

  <!-- Grid de detalles -->
  <div class="about-grid">
    <!-- Foto -->
    <div class="about-photo">
      <div class="about-photo-inner skeleton-wrapper" data-parallax="0.12">
        <img
          src="/generated-image.webp"
          alt="Ariel Campos - Desarrollador"
          class="about-img"
          loading="lazy"
        />
        <div class="skeleton-placeholder"></div>
      </div>
    </div>

    <!-- Info -->
    <div class="about-info">
      <!-- Descripción -->
      <div class="about-description">
        <p>
          Actualmente trabajo en el <strong
            >Departamento de Salud de La Ligua (DESAM) como informático</strong
          > y soy cofundador de <a
            href="https://nitiv.cl"
            target="_blank"
            rel="noopener noreferrer"
            class="about-link">Nitiv SpA.</a
          >, donde lidero el diseño y desarrollo de nuestra infraestructura web
          y aplicaciones SaaS.
        </p>
        <p>
          Me especializo en crear interfaces modernas, rápidas, completamente
          optimizadas para todo tipo de dispositivos y orientadas a resultados,
          aplicando metodologías ágiles como <strong>SCRUM</strong> y principios de
          <strong>Clean Code</strong>.
        </p>
      </div>

      <!-- Datos rápidos -->
      <div class="about-data-card">
        <div class="about-data-row">
          <span class="about-data-label">UBICACIÓN:</span>
          <span class="about-data-value">LA LIGUA, CHILE</span>
        </div>
        <div class="about-data-row">
          <span class="about-data-label">ESTADO:</span>
          <span class="about-data-value about-available"
            >DISPONIBLE PARA PROYECTOS</span
          >
        </div>
        <div class="about-data-row">
          <span class="about-data-label">EMPRESA:</span>
          <span class="about-data-value">DESAM / NITIV SPA</span>
        </div>
      </div>

      <!-- Métricas -->
      <div class="about-stats">
        {
          stats.map((stat) => (
            <div
              class:list={[
                "about-stat",
                { "about-stat--tech": stat.label === "Tecnologías" },
              ]}
            >
              <span class="about-stat-label">{stat.label}</span>
              <span
                class="about-stat-value stat-number"
                data-count-to={stat.value.replace(/[^0-9.]/g, '')}
                data-count-suffix={stat.value.includes('%') ? '%' : stat.value.includes('+') ? '+' : ''}
              >0</span>

              {stat.label === "Tecnologías" && (
                <div class="tech-tooltip">
                  <div class="tech-tooltip-arrow"></div>

                  {/* Partículas que estallan al abrir el tooltip */}
                  <span class="tech-particle" style="--tx:-40px;--ty:-50px;--delay:0s;--size:0.5rem">{}</span>
                  <span class="tech-particle" style="--tx:45px;--ty:-40px;--delay:0.05s;--size:0.6rem">&lt;/&gt;</span>
                  <span class="tech-particle" style="--tx:-30px;--ty:30px;--delay:0.1s;--size:0.45rem">*</span>
                  <span class="tech-particle" style="--tx:35px;--ty:35px;--delay:0.15s;--size:0.55rem">#</span>
                  <span class="tech-particle" style="--tx:-50px;--ty:10px;--delay:0.08s;--size:0.5rem">$</span>
                  <span class="tech-particle" style="--tx:50px;--ty:-20px;--delay:0.12s;--size:0.4rem">_</span>

                  <div class="tech-tooltip-header">
                    <span class="tech-tooltip-icon">&lt;/&gt;</span>
                    <span class="tech-tooltip-title">Stack</span>
                  </div>
                  <div class="tech-tooltip-grid">
                    {techStack.map((tech, i) => (
                      <span
                        class="tech-tooltip-chip"
                        style={`animation-delay: ${i * 0.08}s`}
                      >{tech}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>

      <!-- Botón CV -->
      <div class="about-cv-wrapper">
        <a
          href="/curriculum.pdf"
          download="Curriculum_Vitae_Ariel_Campos.pdf"
          target="_blank"
          class="about-cv-btn"
          data-magnetic
        >
          <svg
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
            ></path>
          </svg>
          DESCARGAR CV
        </a>
      </div>
    </div>
  </div>  </section>

<script>
  (function() {
    const techStat = document.querySelector('.about-stat--tech');
    if (!techStat) return;

    // Click toggle para móvil (el hover no es fiable en touch)
    techStat.addEventListener('click', function(e) {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        this.classList.toggle('tech-active');
      }
    });

    // Cerrar al tocar fuera
    document.addEventListener('click', function(e) {
      if (window.innerWidth <= 768) {
        if (!e.target.closest('.about-stat--tech')) {
          techStat.classList.remove('tech-active');
        }
      }
    });
  })();
</script>

<style>
  .about-section {
    padding: 6rem 2rem 5rem;
    max-width: 1400px;
    margin: 0 auto;
    background: var(--bg-primary);
    transition: background-color 0.4s ease;
    width: 100%;
  }

  .about-header {
    margin-bottom: 4rem;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .about-tag {
    display: inline-block;
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    opacity: 0.5;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .about-title {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin: 0;
    width: 100%;
  }

  .about-title-line {
    font-family: var(--font-display);
    font-size: clamp(5.5rem, 21vw, 15.5rem);
    font-weight: 900;
    color: var(--text-primary);
    text-transform: uppercase;
    line-height: 0.82;
    letter-spacing: -0.02em;
    display: block;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), color 0.4s ease;
    width: 100%;
    transform-origin: bottom left;
    cursor: pointer;
  }

  .about-title-line:hover {
    transform: translateY(-15px) rotate(-1deg);
    color: var(--beige);
  }

  .about-title-accent {
    color: var(--beige);
  }

  .about-bio {
    font-family: var(--font-geist);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 400;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.5;
    margin-bottom: 4rem;
    opacity: 0.85;
    transition: color 0.4s ease;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: 0.8fr 1.2fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .about-photo {
    width: 100%;
  }

  .about-photo-inner {
    border: 1px solid var(--border);
    overflow: hidden;
    background: var(--accent);
    transition: border-color 0.4s ease;
  }

  .about-img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
    transition:
      filter 0.6s ease,
      transform 0.6s ease;
  }

  .about-photo-inner:hover .about-img {
    filter: grayscale(0%);
    transform: scale(1.04);
  }

  .about-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .about-description {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-description p {
    font-family: var(--font-geist);
    font-size: 1rem;
    color: var(--text-primary);
    opacity: 0.7;
    line-height: 1.7;
    margin: 0;
    transition: color 0.4s ease;
  }

  .about-description strong {
    color: var(--text-primary);
    opacity: 1;
    font-weight: 700;
  }

  .about-link {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .about-link:hover {
    opacity: 0.6;
  }

  .about-data-card {
    border: 1px solid var(--border);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    transition: border-color 0.4s ease;
  }

  .about-data-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
    font-family: monospace;
    font-size: 0.8rem;
    transition: border-color 0.4s ease;
  }

  .about-data-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .about-data-label {
    color: var(--text-primary);
    opacity: 0.5;
    letter-spacing: 0.1em;
  }

  .about-data-value {
    color: var(--text-primary);
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: color 0.4s ease;
  }

  .about-available {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .about-stat {
    border: 1px solid var(--border);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.4s ease;
  }

  .about-stat-label {
    font-family: monospace;
    font-size: 0.7rem;
    color: var(--text-primary);
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .about-stat-value {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1;
    transition: color 0.4s ease;
  }

  /* === Hover Tooltip de Tecnologías === */
  .about-stat--tech {
    position: relative;
    cursor: pointer;
    transition: border-color 0.3s ease;
  }

  .about-stat--tech:hover {
    border-color: var(--violet);
  }

  .about-stat--tech:hover .about-stat-value {
    color: var(--violet);
  }

  .tech-tooltip {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.2rem;
    min-width: 240px;
    max-width: 320px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    z-index: 20;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  [data-theme="dark"] .tech-tooltip {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .about-stat--tech:hover .tech-tooltip,
  .about-stat--tech.tech-active .tech-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .tech-tooltip-arrow {
    position: absolute;
    bottom: -6px;
    left: 50%;
    transform: translateX(-50%) rotate(45deg);
    width: 12px;
    height: 12px;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background-color 0.4s ease, border-color 0.4s ease;
  }

  .tech-tooltip-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.8rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border);
  }

  .tech-tooltip-icon {
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--violet);
    background: rgba(161, 153, 255, 0.1);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }

  .tech-tooltip-title {
    font-family: var(--font-geist);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-primary);
    opacity: 0.6;
  }

  .tech-tooltip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tooltip-chip {
    font-family: var(--font-geist);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    padding: 0.25rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: transparent;
    transition: all 0.3s ease, color 0.4s ease, border-color 0.4s ease;
    opacity: 0.7;
    line-height: 1.2;
    /* Animación de flotación tipo ola — solo anima cuando el tooltip es visible */
    animation: chipFloat 2.4s ease-in-out infinite;
    animation-play-state: paused;
    will-change: transform;
  }

  .about-stat--tech:hover .tech-tooltip-chip,
  .about-stat--tech.tech-active .tech-tooltip-chip {
    animation-play-state: running;
  }

  .tech-tooltip-chip:hover {
    border-color: var(--violet);
    color: var(--violet);
    opacity: 1;
    background: rgba(161, 153, 255, 0.06);
    animation-play-state: paused !important;
  }

  @keyframes chipFloat {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  /* === Partículas al abrir el tooltip === */
  .tech-particle {
    position: absolute;
    top: 50%;
    left: 50%;
    font-family: monospace;
    font-weight: 700;
    font-size: var(--size, 0.5rem);
    color: var(--violet);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    text-shadow: 0 0 6px rgba(161, 153, 255, 0.3);
    animation: particleBurst 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
    animation-play-state: paused;
  }

  .about-stat--tech:hover .tech-particle,
  .about-stat--tech.tech-active .tech-particle {
    animation-play-state: running;
  }

  @keyframes particleBurst {
    0% {
      opacity: 1;
      transform: translate(-50%, -50%) translateX(0) translateY(0) scale(0.5);
    }
    60% {
      opacity: 0.8;
      transform: translate(-50%, -50%) translateX(var(--tx, -30px)) translateY(var(--ty, -30px)) scale(1);
    }
    100% {
      opacity: 0;
      transform: translate(-50%, -50%) translateX(var(--tx, -30px)) translateY(var(--ty, -30px)) scale(0.3);
    }
  }

  @media (max-width: 768px) {
    .tech-tooltip {
      position: fixed;
      bottom: auto;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0.95);
      min-width: 260px;
      max-width: 85vw;
      z-index: 100;
    }

    .tech-tooltip-arrow {
      display: none;
    }

    .about-stat--tech:hover .tech-tooltip,
    .about-stat--tech.tech-active .tech-tooltip {
      transform: translate(-50%, -50%) scale(1);
    }

    /* Overlay semitransparente al hacer hover/click en móvil */
    .about-stat--tech:hover::after {
      content: '';
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.3);
      z-index: 19;
      pointer-events: none;
    }
  }

  .about-cv-wrapper {
    margin-top: 0.5rem;
  }

  .about-cv-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: var(--font-geist);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    background: transparent;
    transition:
      background-color 0.3s ease,
      color 0.3s ease,
      border-color 0.4s ease;
    cursor: none;
  }

  .about-cv-btn:hover {
    background: var(--text-primary);
    color: var(--bg-primary);
    border-color: var(--text-primary);
  }

  .about-cv-btn svg {
    transition: inherit;
  }
</style>
